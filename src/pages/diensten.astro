---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const services = [
  {
    title: "Maatwerksoftware",
    description:
      "Bedrijfsspecifieke applicaties die exact uw werkproces volgen. Van eerste analyse tot productie-roll-out — we bouwen software die past zoals een handschoen.",
    features: [
      "Procesanalyse en design",
      "Iteratieve ontwikkeling met snelle feedback",
      "Schaalbare architectuur",
      "Volledige eigendom van uw oplossing",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    title: "Webplatformen",
    description:
      "Moderne web-applicaties voor klanten, partners of medewerkers. Veilig, snel en toegankelijk vanuit elke browser — zonder installatie of onderhoud aan klantzijde.",
    features: [
      "Responsief design voor desktop en mobiel",
      "Single sign-on en role-based access",
      "Integratie met bestaande systemen",
      "Hosting en updates inbegrepen",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  },
  {
    title: "Mobiele toepassingen",
    description:
      "Native en cross-platform apps voor iOS en Android. Voor medewerkers in het veld, monteurs op locatie, of klanten die onderweg willen werken.",
    features: [
      "Offline-first ontwerp",
      "Camera en GPS-integratie",
      "Push notifications",
      "Naadloze sync met centrale systemen",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Integraties",
    description:
      "Koppelingen met de Belgische ecosystemen: eID, Peppol, banken, boekhoudpakketten en overheidsdiensten. We kennen de standaarden en de valkuilen.",
    features: [
      "Peppol e-facturatie",
      "eID en It's me authenticatie",
      "CODA en SEPA-koppeling",
      "Exact, Octopus, Yuki, Wings",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
  },
];

const process = [
  {
    step: "01",
    title: "Verkenning",
    description:
      "We luisteren. Naar uw bedrijf, uw processen, uw frustraties met huidige tools. Geen vragenlijsten — gewoon een gesprek.",
  },
  {
    step: "02",
    title: "Voorstel",
    description:
      "Een helder voorstel met scope, planning en richtprijs. Geen verrassingen achteraf. U beslist wat zinvol is.",
  },
  {
    step: "03",
    title: "Iteratieve bouw",
    description:
      "Korte cycli met tussentijdse demo's. U geeft feedback, wij passen aan. Continuous delivery, geen big-bang-launch.",
  },
  {
    step: "04",
    title: "Productie en ondersteuning",
    description:
      "Roll-out met opleidings- en support-pakket. Daarna lange-termijn onderhoud en doorontwikkeling.",
  },
];
---

<BaseLayout
  title="Diensten — ADM-Concept"
  description="Maatwerksoftware, webplatformen, mobiele apps en integraties. Van analyse tot productie en lange-termijn ondersteuning."
>
  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-mesh-1">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-block px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-xs font-semibold text-emerald-700 mb-4">
          Diensten
        </div>
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Wat we bouwen,<br />
          en hoe we werken.
        </h1>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Van eerste idee tot productie en doorlopend onderhoud. We begeleiden
          uw digitaliseringstraject van A tot Z.
        </p>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <article class="group p-8 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-xl transition-all duration-300">
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 text-slate-700 flex items-center justify-center mb-6 group-hover:from-brand-100 group-hover:to-brand-200 group-hover:text-brand-700 transition-all">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-3">{service.title}</h3>
              <p class="text-slate-600 leading-relaxed mb-6">{service.description}</p>
              <ul class="space-y-2">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-slate-700">
                    <svg
                      class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 lg:py-32 bg-slate-50/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-purple-50 border border-purple-100 text-xs font-semibold text-purple-700 mb-4">
          Onze werkwijze
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Vier fasen,<br />
          geen verrassingen
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          process.map((phase) => (
            <div class="relative p-8 bg-white rounded-2xl border border-slate-200">
              <div class="text-5xl font-extrabold text-slate-200 mb-4">{phase.step}</div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{phase.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{phase.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA
    title="Welke uitdaging willen we samen aanpakken?"
    description="Begin met een vrijblijvend gesprek. We luisteren, denken mee en geven u een eerlijk advies — ook als dat is dat u geen software nodig heeft."
  />
</BaseLayout>
