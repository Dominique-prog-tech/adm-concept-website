---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const yearsActive = new Date().getFullYear() - 1997;
---

<BaseLayout
  title="Over ons — ADM-Concept"
  description={`${yearsActive} jaar ervaring in maatwerksoftware. Belgisch bedrijf, gevestigd in Waregem. Onze missie: software die werkt zoals uw organisatie werkt.`}
>
  <!-- Hero with image -->
  <section class="relative py-16 lg:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="inline-block px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-semibold text-slate-700 mb-4">
            Over ons
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Sinds 1997 bouwen<br />
            aan Belgische software.
          </h1>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Bijna drie decennia ervaring in het vertalen van bedrijfsprocessen
            naar software die mensen graag gebruiken. Klein team, grote
            toewijding, vanuit Waregem.
          </p>
        </div>
        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-200 to-purple-200 rounded-3xl blur-2xl opacity-50"></div>
          <img
            src="/images/team-collaboration.jpg"
            alt="Team aan het samenwerken in een moderne werkomgeving"
            class="relative w-full h-[420px] object-cover rounded-2xl shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="prose prose-lg prose-slate max-w-none">
        <h2 class="text-3xl font-bold text-slate-900 mb-6">Ons verhaal</h2>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          ADM-Concept ontstond uit een eenvoudige observatie: standaardsoftware
          dwingt bedrijven om hun manier van werken aan te passen. Bedrijven met
          gespecialiseerde processen verdienen software die past, niet andersom.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed mb-6">
          Sinds onze start hebben we organisaties geholpen om
          hun processen te digitaliseren — van kredietbemiddeling tot
          schoonmaakplanning, van projectbeheer tot integraties met de Belgische
          overheid. Onze aanpak is constant gebleven: luisteren, begrijpen,
          bouwen, ondersteunen.
        </p>
        <p class="text-lg text-slate-600 leading-relaxed">
          Vandaag zijn we een gevestigd softwarebedrijf met drie eigen platformen
          en meer dan 20 actieve maatwerkprojecten. Klanten van het eerste uur
          werken nog steeds met ons — geen toeval, wel onze beste referentie.
        </p>
      </div>
    </div>
  </section>

  <!-- Image break -->
  <section class="relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <img
        src="/images/developer-screen.jpg"
        alt="Code op een developer-scherm"
        class="w-full h-[400px] object-cover rounded-3xl shadow-xl"
        loading="lazy"
      />
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 lg:py-32 bg-slate-50/50 mt-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Wat ons drijft
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="w-12 h-12 rounded-xl bg-brand-100 text-brand-700 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Eerlijkheid eerst</h3>
          <p class="text-slate-600 leading-relaxed">
            Geen verkooppraatjes. We zeggen wat we denken — ook als dat is dat een
            ander beter past voor uw situatie.
          </p>
        </div>

        <div>
          <div class="w-12 h-12 rounded-xl bg-emerald-100 text-emerald-700 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Snelheid in iteratie</h3>
          <p class="text-slate-600 leading-relaxed">
            Geen jaar wachten op een eerste versie. We werken in korte cycli met
            tussentijdse demo's. U geeft feedback, wij passen aan.
          </p>
        </div>

        <div>
          <div class="w-12 h-12 rounded-xl bg-purple-100 text-purple-700 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Voor de lange termijn</h3>
          <p class="text-slate-600 leading-relaxed">
            Software is geen project, het is een investering. We bouwen voor jaren
            gebruik, met onderhoud, updates en doorontwikkeling.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-12 text-center">
        <div>
          <div class="text-5xl font-extrabold text-slate-900 tracking-tight">{yearsActive}</div>
          <div class="mt-2 text-sm text-slate-500 uppercase tracking-wider">Jaar ervaring</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-slate-900 tracking-tight">3</div>
          <div class="mt-2 text-sm text-slate-500 uppercase tracking-wider">Eigen platformen</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-slate-900 tracking-tight">20+</div>
          <div class="mt-2 text-sm text-slate-500 uppercase tracking-wider">Actieve maatwerkprojecten</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-slate-900 tracking-tight">100%</div>
          <div class="mt-2 text-sm text-slate-500 uppercase tracking-wider">Made in Belgium</div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
