---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import CaseHeroBanner from "../../components/CaseHeroBanner.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const cases = await getCollection("realisaties", ({ data }) => !data.draft && data.lang === "nl");
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Andere cases voor "Bekijk ook"
const allCases = (await getCollection("realisaties", ({ data }) => !data.draft && data.lang === "nl"))
  .filter((c) => c.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

const platformBadge: Record<string, string> = {
  Maatwerk: "bg-slate-50 text-slate-700 border-slate-200",
  CreditSoft: "bg-blue-50 text-blue-700 border-blue-200",
  CleanOps: "bg-teal-50 text-teal-700 border-teal-200",
  Nimble: "bg-purple-50 text-purple-700 border-purple-200",
};

// Icon paths voor capabilities-blokken (Heroicons outline stijl)
const ICONS: Record<string, string> = {
  document: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  currency: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  users: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>`,
  computer: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
  link: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>`,
  layers: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>`,
  chart: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  sparkle: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
};

const capabilitiesHeading = "Wat het platform vandaag doet";
---

<BaseLayout
  title={`${entry.data.title} — ADM-Concept`}
  description={entry.data.summary}
  ogImage={entry.data.heroImage}
>
  <!-- Back link -->
  <section class="pt-8 lg:pt-12">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <a href="/realisaties" class="inline-flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Alle realisaties
      </a>
    </div>
  </section>

  <!-- Hero -->
  <section class="py-8 lg:py-12">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class={`inline-block px-2.5 py-1 rounded-full border text-xs font-semibold ${platformBadge[entry.data.platform]}`}>
          {entry.data.platform}
        </span>
        <span class="inline-block px-2.5 py-1 rounded-full bg-slate-100 text-xs font-medium text-slate-600">
          {entry.data.sector}
        </span>
        <span class="text-xs text-slate-500">· {entry.data.year}</span>
      </div>
      <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed">
        {entry.data.summary}
      </p>
      {entry.data.technologies.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {entry.data.technologies.map((t) => (
            <span class="px-2.5 py-1 rounded-full bg-slate-100 text-xs font-medium text-slate-600">{t}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  {entry.data.customerLogo && entry.data.brandColor ? (
    <section class="py-6">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <CaseHeroBanner
          customer={entry.data.customer}
          customerLogo={entry.data.customerLogo}
          brandColor={entry.data.brandColor}
          year={entry.data.year}
          language="nl"
        />
      </div>
    </section>
  ) : entry.data.heroImage && (
    <section class="py-6">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <img src={entry.data.heroImage} alt={entry.data.customer}
          class="w-full aspect-[16/9] object-cover rounded-3xl shadow-2xl" />
      </div>
    </section>
  )}

  {entry.data.capabilities && entry.data.capabilities.length > 0 && (
    <section class="py-12 lg:py-16 bg-slate-50/60">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight text-slate-900 mb-8">
          {capabilitiesHeading}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {entry.data.capabilities.map((c) => (
            <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-md transition-all">
              <div class="w-11 h-11 rounded-lg bg-brand-50 text-brand-700 flex items-center justify-center mb-4">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <Fragment set:html={ICONS[c.icon] ?? ICONS.document} />
                </svg>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-2">{c.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{c.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Body content -->
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="prose prose-slate prose-lg max-w-none
                  prose-headings:font-extrabold prose-headings:tracking-tight
                  prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
                  prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-slate-700 prose-p:leading-relaxed
                  prose-a:text-brand-600 prose-strong:text-slate-900
                  prose-ul:my-4 prose-li:my-1">
        <Content />
      </div>
    </div>
  </section>

  {allCases.length > 0 && (
    <section class="py-16 lg:py-20 bg-slate-50/60">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-8">Bekijk ook</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {allCases.map((c) => (
            <a href={`/realisaties/${c.id}`}
              class="group p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-lg transition-all">
              <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class={`inline-block px-2.5 py-1 rounded-full border text-xs font-semibold ${platformBadge[c.data.platform]}`}>
                  {c.data.platform}
                </span>
                <span class="text-xs text-slate-500">{c.data.sector}</span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 group-hover:text-brand-700 transition-colors">{c.data.title}</h3>
              <p class="mt-2 text-sm text-slate-600 leading-relaxed line-clamp-2">{c.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA
    title="Een vergelijkbare uitdaging?"
    description="Elke realisatie hier begon ooit met een verkennend gesprek. We luisteren, denken mee en geven een eerlijk advies."
  />
</BaseLayout>
