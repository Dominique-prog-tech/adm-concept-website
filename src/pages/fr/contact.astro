---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact — ADM-Concept"
  description="Contactez ADM-Concept. Pas de discours commercial — mais un échange honnête sur votre défi."
>
  <section class="py-16 lg:py-24 bg-mesh-1 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="inline-block px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-semibold text-slate-700 mb-4">
            Contact
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Parlons-en.
          </h1>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-xl">
            Pas de discours commercial, pas de marathon de formulaires. Envoyez-nous
            un e-mail ou appelez-nous directement. Nous écoutons votre défi et
            voyons si nous pouvons aider.
          </p>
        </div>
        <div class="lg:col-span-2 relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-brand-200 to-blue-200 rounded-3xl blur-2xl opacity-50"></div>
          <img
            src="/images/business-meeting.jpg"
            alt="Un entretien sans engagement sur votre défi"
            class="relative w-full h-[320px] object-cover rounded-2xl shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Contact info -->
        <div class="lg:col-span-1 space-y-8">
          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">E-mail</h3>
            <a
              href="mailto:info@adm-concept.be"
              class="text-lg font-medium text-slate-900 hover:text-brand-600 transition-colors"
              >info@adm-concept.be</a
            >
            <p class="mt-1 text-sm text-slate-500">Nous répondons dans un jour ouvrable.</p>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Téléphone</h3>
            <a
              href="tel:+32475507937"
              class="text-lg font-medium text-slate-900 hover:text-brand-600 transition-colors"
              >+32 475 50 79 37</a
            >
            <p class="mt-1 text-sm text-slate-500">Joignable en semaine, 9h–18h.</p>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Adresse</h3>
            <address class="not-italic text-lg text-slate-700 leading-relaxed">
              ADM-Concept<br />
              Zuiderlaan 37 bus 41<br />
              8790 Waregem<br />
              Belgique
            </address>
          </div>

          <div>
            <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Documentation</h3>
            <ul class="space-y-1 text-sm">
              <li>
                <a href="https://docs.creditsoft.be/fr/" target="_blank" rel="noopener" class="text-slate-700 hover:text-brand-600 transition-colors">docs.creditsoft.be →</a>
              </li>
              <li>
                <a href="https://docs.cleanops.eu/fr/" target="_blank" rel="noopener" class="text-slate-700 hover:text-brand-600 transition-colors">docs.cleanops.eu →</a>
              </li>
              <li>
                <a href="https://docs.nimble-erp.eu/fr/" target="_blank" rel="noopener" class="text-slate-700 hover:text-brand-600 transition-colors">docs.nimble-erp.eu →</a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-2">
          <!-- Message de succès (apparaît après envoi) -->
          <div
            id="form-success"
            class="hidden bg-white p-8 lg:p-10 rounded-2xl border border-emerald-200 shadow-sm text-center"
          >
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-emerald-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-3">Merci pour votre message !</h2>
            <p class="text-slate-600 leading-relaxed">
              Nous avons bien reçu votre demande et vous recontacterons
              personnellement dans un jour ouvrable.
            </p>
            <a href="/fr/" class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-lg transition-colors">
              Retour à l'accueil
            </a>
          </div>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="bg-white p-8 lg:p-10 rounded-2xl border border-slate-200 shadow-sm"
          >
            <!-- Configuration Web3Forms -->
            <input type="hidden" name="access_key" value="fb462c2f-81eb-4ba5-8914-0472bf84af0b" />
            <input type="hidden" name="subject" value="Nouveau message via le site adm-concept.be" />
            <input type="hidden" name="from_name" value="ADM-Concept Site Web (Contact FR)" />

            <!-- Honeypot (anti-spam) -->
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <h2 class="text-2xl font-bold text-slate-900 mb-2">Envoyer un message</h2>
            <p class="text-sm text-slate-500 mb-8">
              Parlez-nous de votre projet ou posez votre question. Nous réagissons rapidement.
            </p>

            <div class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-slate-700 mb-2">
                    Nom <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                  />
                </div>
                <div>
                  <label for="company" class="block text-sm font-medium text-slate-700 mb-2">
                    Entreprise
                  </label>
                  <input
                    type="text"
                    id="company"
                    name="company"
                    class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-2">
                    E-mail <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">
                    Téléphone
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                  />
                </div>
              </div>

              <div>
                <label for="topic" class="block text-sm font-medium text-slate-700 mb-2">
                  Sujet
                </label>
                <select
                  id="topic"
                  name="onderwerp"
                  class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                >
                  <option value="">Sélectionner</option>
                  <option value="CreditSoft">CreditSoft</option>
                  <option value="CleanOps">CleanOps</option>
                  <option value="Nimble">Nimble</option>
                  <option value="Sur mesure">Logiciel sur mesure</option>
                  <option value="Autre">Autre</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-slate-700 mb-2">
                  Message <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 bg-white border border-slate-300 rounded-lg focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
                  placeholder="Parlez-nous de votre défi ou de votre question..."></textarea>
              </div>

              <!-- Message d'erreur -->
              <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                Une erreur est survenue lors de l'envoi. Réessayez ou écrivez directement à
                <a href="mailto:info@adm-concept.be" class="font-semibold underline">info@adm-concept.be</a>.
              </div>

              <div class="pt-2">
                <button
                  id="submit-btn"
                  type="submit"
                  class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 text-base font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-xl transition-all shadow-lg hover:shadow-xl disabled:opacity-60 disabled:cursor-not-allowed"
                >
                  <span id="submit-text">Envoyer le message</span>
                  <svg
                    id="submit-icon"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                  <svg
                    id="submit-spinner"
                    class="hidden w-5 h-5 animate-spin"
                    fill="none"
                    viewBox="0 0 24 24"
                  >
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>
                <p class="mt-3 text-xs text-slate-500">
                  Vos données sont utilisées uniquement pour répondre à votre message.
                </p>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const successDiv = document.getElementById("form-success");
    const errorDiv = document.getElementById("form-error");
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const submitText = document.getElementById("submit-text");
    const submitIcon = document.getElementById("submit-icon");
    const submitSpinner = document.getElementById("submit-spinner");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      errorDiv?.classList.add("hidden");

      // État de chargement
      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.textContent = "Envoi en cours...";
      submitIcon?.classList.add("hidden");
      submitSpinner?.classList.remove("hidden");

      const formData = new FormData(form);

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          form.classList.add("hidden");
          successDiv?.classList.remove("hidden");
          window.scrollTo({ top: 0, behavior: "smooth" });
        } else {
          throw new Error(result.message || "Erreur inconnue");
        }
      } catch (error) {
        console.error("Form submission error:", error);
        errorDiv?.classList.remove("hidden");

        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.textContent = "Envoyer le message";
        submitIcon?.classList.remove("hidden");
        submitSpinner?.classList.add("hidden");
      }
    });
  </script>
</BaseLayout>
