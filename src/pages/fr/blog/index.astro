---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft && data.lang === "fr"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString("fr-BE", { day: "numeric", month: "long", year: "numeric" });

// Strip "fr/" prefix from post.id to get the clean slug for URLs.
const slugOf = (id: string) => id.replace(/^fr\//, "");
---

<BaseLayout
  title="Blog — ADM-Concept"
  description="Études de cas clients, mises à jour de nos plateformes et regards sur le développement logiciel, Peppol et la digitalisation."
>
  <section class="py-16 lg:py-24 bg-mesh-1">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-block px-3 py-1 rounded-full bg-slate-100 border border-slate-200 text-xs font-semibold text-slate-700 mb-4">
          Blog
        </div>
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Études de cas et actualités
        </h1>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Comment nous aidons les entreprises à grandir grâce à des logiciels
          intelligents, des mises à jour produits et des éclairages sur la
          digitalisation en Belgique.
        </p>
        <div class="mt-6 flex items-center gap-4">
          <a
            href="/rss.xml"
            class="inline-flex items-center gap-2 text-sm font-medium text-slate-700 hover:text-brand-600 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 014 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z" />
            </svg>
            Flux RSS
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      {
        posts.length === 0 ? (
          <p class="text-slate-600">Aucun article de blog disponible pour le moment.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <article class="group flex flex-col bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-slate-300 hover:shadow-xl transition-all duration-300">
                {post.data.image && (
                  <a href={`/fr/blog/${slugOf(post.id)}`} class="block aspect-[16/9] overflow-hidden bg-slate-100">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </a>
                )}
                <div class="flex flex-col flex-1 p-6">
                  <div class="flex items-center gap-2 mb-3 text-xs text-slate-500">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <span>·</span>
                    <span>{post.data.author}</span>
                  </div>
                  <h2 class="text-xl font-bold text-slate-900 mb-3 leading-tight group-hover:text-brand-600 transition-colors">
                    <a href={`/fr/blog/${slugOf(post.id)}`}>{post.data.title}</a>
                  </h2>
                  <p class="text-sm text-slate-600 leading-relaxed mb-4 flex-1">
                    {post.data.description}
                  </p>
                  {post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2 py-0.5 text-xs font-medium text-slate-600 bg-slate-100 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <a
                    href={`/fr/blog/${slugOf(post.id)}`}
                    class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700"
                  >
                    Lire plus
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
