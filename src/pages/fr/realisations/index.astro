---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTA from "../../../components/CTA.astro";
import CaseHeroBanner from "../../../components/CaseHeroBanner.astro";
import { getCollection } from "astro:content";

const cases = (await getCollection("realisaties", ({ data }) => !data.draft && data.lang === "fr"))
  .sort((a, b) => a.data.order - b.data.order);

const featured = cases.filter((c) => c.data.featured);
const others = cases.filter((c) => !c.data.featured);

const platformBadge: Record<string, string> = {
  Maatwerk: "bg-slate-50 text-slate-700 border-slate-200",
  CreditSoft: "bg-blue-50 text-blue-700 border-blue-200",
  CleanOps: "bg-teal-50 text-teal-700 border-teal-200",
  Nimble: "bg-purple-50 text-purple-700 border-purple-200",
};

const platformLabel: Record<string, string> = {
  Maatwerk: "Sur mesure",
  CreditSoft: "CreditSoft",
  CleanOps: "CleanOps",
  Nimble: "Nimble",
};

// FR entries hebben id "fr/<slug>", strip de prefix voor de URL
const slugOf = (id: string) => id.replace(/^fr\//, "");
---

<BaseLayout
  title="Réalisations — ADM-Concept"
  description="Cas clients et réalisations d'ADM-Concept : projets sur mesure et extensions de nos plateformes CreditSoft, CleanOps et Nimble. Depuis 1997."
>
  <section class="py-16 lg:py-24 bg-mesh-1 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-block px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-xs font-semibold text-emerald-700 mb-4">
          Réalisations
        </div>
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Ce que nous construisons,<br />
          pour qui ça fonctionne.
        </h1>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Un aperçu de nos projets : logiciels sur mesure et extensions de nos
          propres plateformes pour des clients de différents secteurs. Chaque
          cas montre le défi, l'approche et le résultat.
        </p>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-10">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">À la une</h2>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {featured.map((c) => (
            <a href={`/fr/realisations/${slugOf(c.id)}`}
              class="group relative overflow-hidden rounded-3xl bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl transition-all">
              {c.data.customerLogo && c.data.brandColor ? (
                <div class="group-hover:[&_img]:scale-105 [&_img]:transition-transform [&_img]:duration-500">
                  <CaseHeroBanner
                    customer={c.data.customer}
                    customerLogo={c.data.customerLogo}
                    brandColor={c.data.brandColor}
                    year={c.data.year}
                    language="fr"
                    variant="card"
                  />
                </div>
              ) : c.data.heroImage && (
                <div class="aspect-[16/9] overflow-hidden bg-slate-100">
                  <img src={c.data.heroImage} alt={c.data.customer}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
              )}
              <div class="p-8">
                <div class="flex flex-wrap items-center gap-2 mb-4">
                  <span class={`inline-block px-2.5 py-1 rounded-full border text-xs font-semibold ${platformBadge[c.data.platform]}`}>
                    {platformLabel[c.data.platform]}
                  </span>
                  <span class="inline-block px-2.5 py-1 rounded-full bg-slate-100 text-xs font-medium text-slate-600">
                    {c.data.sector}
                  </span>
                  <span class="text-xs text-slate-500">· {c.data.year}</span>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-3 group-hover:text-brand-700 transition-colors">{c.data.title}</h3>
                <p class="text-slate-600 leading-relaxed line-clamp-3">{c.data.summary}</p>
                <div class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 group-hover:gap-2 transition-all">
                  Voir le cas
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/>
                  </svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {others.length > 0 && (
    <section class="py-16 lg:py-20 bg-slate-50/60">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="mb-10">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Autres réalisations</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {others.map((c) => (
            <a href={`/fr/realisations/${slugOf(c.id)}`}
              class="group p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-lg transition-all">
              <div class="flex flex-wrap items-center gap-2 mb-4">
                <span class={`inline-block px-2.5 py-1 rounded-full border text-xs font-semibold ${platformBadge[c.data.platform]}`}>
                  {platformLabel[c.data.platform]}
                </span>
                <span class="text-xs text-slate-500">{c.data.sector} · {c.data.year}</span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-brand-700 transition-colors">{c.data.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed line-clamp-3">{c.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA
    title="Un défi similaire ?"
    description="Chaque réalisation ici a commencé un jour par un entretien exploratoire. Nous écoutons, réfléchissons avec vous et donnons un conseil honnête."
  />
</BaseLayout>
