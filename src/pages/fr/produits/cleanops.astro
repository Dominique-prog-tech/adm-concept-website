---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTA from "../../../components/CTA.astro";
import CleanOpsMockup from "../../../components/mockups/CleanOpsMockup.astro";

const modules = [
  {
    title: "Planning & Dispatch",
    description:
      "Planning journalier et hebdomadaire des équipes, localisation en temps réel et affectation des ordres de travail. Planifiez les contrats d'entretien et les interventions sans accroc.",
  },
  {
    title: "Gestion des contrats",
    description:
      "Devis avec signature numérique. Planification automatique des travaux d'entretien récurrents pour villes, syndics et entreprises.",
  },
  {
    title: "Bons de travail et inspections vidéo",
    description:
      "Documentez les interventions avec des bons de travail numériques et des rapports vidéo. Générez les attestations légales directement depuis le système.",
  },
  {
    title: "CRM",
    description:
      "Gestion des clients pour villes, syndics, entreprises et particuliers dans un système central unique.",
  },
  {
    title: "Facturation & Peppol",
    description:
      "Génération automatique de factures à partir des bons de travail, envoi Peppol, intégration bancaire et gestion automatisée des rappels.",
  },
  {
    title: "Évolue avec vous",
    description:
      "Adapté aux entreprises de 2 à 20 équipes. Commencez petit, évoluez au rythme de la croissance de votre organisation.",
  },
];

const doelgroepen = [
  "Services de débouchage et fosses septiques",
  "Nettoyage d'égouts et débouchage",
  "Inspections vidéo",
  "Contrats d'entretien pour villes",
  "Syndics et entreprises",
  "Interventions chez les particuliers",
];
---

<BaseLayout
  title="CleanOps — Logiciel pour le nettoyage d'égouts et le débouchage"
  description="Logiciel tout-en-un pour les services de débouchage et les entreprises d'assainissement : planning, bons de travail, inspections vidéo et facturation. Pour entreprises de 2 à 20 équipes."
  ogImage="/images/og/cleanops.png"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/products/cleanops.svg"
              alt="CleanOps logo"
              class="w-20 h-20 rounded-2xl shadow-xl shadow-slate-900/10"
              width="80"
              height="80"
            />
            <span class="text-sm font-semibold text-teal-700">PLATEFORME</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            CleanOps
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            Logiciel tout-en-un pour le nettoyage d'égouts et le débouchage.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Planifiez équipes et véhicules, suivez les ordres, documentez les
            interventions et facturez correctement. La plateforme opérationnelle
            qui intègre planning, bons de travail, rapports vidéo et facturation
            pour les services de débouchage et les entreprises d'assainissement.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://www.cleanops.eu" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-teal-600 hover:bg-teal-700 rounded-xl transition-all shadow-lg">
              Visiter cleanops.eu
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <a href="/fr/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Demander une démo
            </a>
            <a href="https://docs.cleanops.eu/fr/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-700 hover:text-slate-900 rounded-xl transition-all">
              Documentation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <CleanOpsMockup />
        </div>
      </div>
    </div>
  </section>

  <!-- Doelgroep -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-teal-50 border border-teal-100 text-xs font-semibold text-teal-700 mb-4">
          Pour qui
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Spécifiquement conçu pour le secteur
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          CleanOps est développé en collaboration avec des entreprises d'assainissement et de débouchage — pas une adaptation d'ERP générique, mais un logiciel qui connaît le secteur.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {doelgroepen.map((d) => (
          <div class="flex items-center gap-3 p-4 bg-white border border-slate-200 rounded-xl">
            <svg class="w-5 h-5 text-teal-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-800 font-medium">{d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-teal-50 border border-teal-100 text-xs font-semibold text-teal-700 mb-4">
          Fonctionnalités
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Tout ce dont un service de débouchage a besoin
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-teal-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Prêt à digitaliser votre service de débouchage ?"
    description="Nous vous montrons dans une démo sans engagement comment CleanOps réunit planning, bons de travail et facturation — adapté à la réalité du nettoyage d'égouts."
    buttonText="Planifier une démo"
  />
</BaseLayout>
