---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTA from "../../../components/CTA.astro";
import NimbleMockup from "../../../components/mockups/NimbleMockup.astro";

const modules = [
  { title: "Projets", description: "Phases de projet, jalons, livrables — vue d'ensemble de tous vos chantiers en cours." },
  { title: "États d'avancement", description: "Factures partielles périodiques basées sur le pourcentage d'exécution." },
  { title: "Planning", description: "Planifiez équipes et matériel par projet. Vue visuelle dans agenda et calendrier." },
  { title: "Devis", description: "Établissez, suivez et convertissez les devis en projets." },
  { title: "Finances", description: "Tableau de bord des ventes, factures, rappels, factures d'achat." },
  { title: "Intégrations", description: "Exact Online, Peppol, enregistrement du temps, gestion du matériel." },
];
---

<BaseLayout
  title="Nimble — ERP pour les entreprises orientées projets"
  description="Gestion de projet, états d'avancement, planning et facturation pour la construction, l'installation et l'exécution de projets."
  ogImage="/images/og/nimble.png"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-purple-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/products/nimble.svg"
              alt="Nimble logo"
              class="w-20 h-20 rounded-2xl shadow-xl shadow-slate-900/10"
              width="80"
              height="80"
            />
            <span class="text-sm font-semibold text-purple-700">PLATEFORME</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Nimble
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            ERP pour ceux qui travaillent en mode projet — construction, installation, exécution.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Du devis au décompte final — Nimble accompagne l'ensemble du processus
            projet. Avec des fonctionnalités dont les entreprises projet ont
            réellement besoin : états d'avancement, gestion du matériel,
            planification des équipes, enregistrement du temps.
          </p>
          <div class="mt-4 p-3 bg-purple-50 border border-purple-200 rounded-lg text-sm text-purple-900">
            <strong>Site produit en construction</strong> — visitez entre-temps notre documentation ou contactez-nous pour une démo.
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/fr/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-purple-600 hover:bg-purple-700 rounded-xl transition-all shadow-lg">
              Demander une démo
            </a>
            <a href="https://docs.nimble-erp.eu" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Consulter la documentation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <NimbleMockup />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Construit pour les organisations projet
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-purple-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Prêt pour une gestion de projet de haut niveau ?"
    description="Réservez une démo sans engagement et découvrez comment Nimble simplifie votre flux projet — du devis à la livraison."
    buttonText="Planifier une démo"
  />
</BaseLayout>
