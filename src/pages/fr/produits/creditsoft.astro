---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CTA from "../../../components/CTA.astro";
import CreditSoftMockup from "../../../components/mockups/CreditSoftMockup.astro";

const modules = [
  {
    title: "Gestion des clients",
    description:
      "Fiches clients centralisées avec stockage conforme au RGPD. Toutes les informations de vos clients en un seul endroit sécurisé.",
  },
  {
    title: "Gestion des dossiers",
    description:
      "Plusieurs dossiers par client avec suivi des statuts. Suivez le cycle de vie de chaque dossier — du premier contact jusqu'à la clôture.",
  },
  {
    title: "Gestion documentaire",
    description:
      "Listes de contrôle automatiques par type de dossier. Les clients téléchargent les documents via leur propre portail — fini les échanges d'e-mails.",
  },
  {
    title: "Gestion bancaire",
    description:
      "Soumettez des dossiers simultanément à plusieurs banques. Suivez par banque le statut, la communication et les décisions.",
  },
  {
    title: "Commissions",
    description:
      "Calcul et répartition automatiques. Génération de bordereaux, schémas de commission par intermédiaire, contrôle et validation.",
  },
  {
    title: "Prévisions",
    description:
      "Prévisions de revenus par bureau, apporteur ou dossier. Visibilité sur votre trésorerie des prochains mois.",
  },
  {
    title: "Portail client",
    description:
      "Les clients consultent le statut de leur dossier et peuvent téléverser des documents. Transparence sans passer des heures au téléphone.",
  },
  {
    title: "Regroupements",
    description:
      "Pour les bureaux de crédit et collaborations : contrôle central et répartition transparente des dossiers et commissions.",
  },
];

const doelgroepen = [
  {
    title: "Courtiers en crédit indépendants",
    description: "Pour une gestion professionnelle sans chaos administratif.",
  },
  {
    title: "Bureaux de crédit",
    description: "Pour une vision complète des dossiers et des revenus.",
  },
  {
    title: "Regroupements",
    description: "Pour un contrôle centralisé et une répartition transparente.",
  },
];
---

<BaseLayout
  title="CreditSoft — Plateforme pour les courtiers en crédit professionnels"
  description="La plateforme tout-en-un pour l'intermédiation en crédit : gestion des clients, dossiers, gestion bancaire, commissions et prévisions. Pour courtiers indépendants, bureaux et regroupements."
  ogImage="/images/og/creditsoft.png"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/products/creditsoft.svg"
              alt="CreditSoft logo"
              class="w-20 h-20 rounded-2xl shadow-xl shadow-slate-900/10"
              width="80"
              height="80"
            />
            <span class="text-sm font-semibold text-blue-700">PLATEFORME</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            CreditSoft
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            La plateforme tout-en-un pour les courtiers en crédit professionnels.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Centralisez l'intégralité du processus d'intermédiation en crédit :
            gestion des clients, traitement des dossiers, stockage documentaire,
            calcul des commissions et prévisions de revenus dans un seul système
            sécurisé. Développé en collaboration avec de véritables courtiers en
            crédit.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://www.creditsoft.be" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-lg">
              Visiter creditsoft.be
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <a href="/fr/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Demander une démo
            </a>
            <a href="https://docs.creditsoft.be/fr/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-700 hover:text-slate-900 rounded-xl transition-all">
              Documentation
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <CreditSoftMockup />
        </div>
      </div>
    </div>
  </section>

  <!-- Doelgroep -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-4">
          Pour qui
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Trois échelles, une plateforme
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {doelgroepen.map((d) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{d.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-4">
          Fonctionnalités
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Tout ce dont un courtier en crédit a besoin
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-blue-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USP block -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="p-10 bg-white border border-slate-200 rounded-2xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Pourquoi CreditSoft ?</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Spécialisation dans le secteur du crédit</strong> — pas un ERP générique, mais un logiciel conçu pour et avec les courtiers en crédit.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Fonctionnalités intégrées de commission et de regroupement</strong> — pas besoin de contournement.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Développé en collaboration avec de vrais courtiers en crédit</strong> — les retours du terrain façonnent chaque version.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <CTA
    title="Intéressé par CreditSoft ?"
    description="Nous vous montrons volontiers, via une démo en ligne, comment la plateforme fonctionnerait dans votre bureau. Sans engagement et sans discours commercial."
    buttonText="Planifier une démo"
  />
</BaseLayout>
