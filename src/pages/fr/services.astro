---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";

const services = [
  {
    title: "Logiciels sur mesure",
    description:
      "Des applications spécifiques à votre entreprise qui suivent exactement votre processus de travail. De la première analyse au déploiement en production — nous construisons des logiciels qui s'ajustent comme un gant.",
    features: [
      "Analyse et conception des processus",
      "Développement itératif avec retours rapides",
      "Architecture évolutive",
      "Pleine propriété de votre solution",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    title: "Plateformes web",
    description:
      "Des applications web modernes pour vos clients, partenaires ou collaborateurs. Sécurisées, rapides et accessibles depuis n'importe quel navigateur — sans installation ni maintenance côté client.",
    features: [
      "Design responsive pour ordinateur et mobile",
      "Single sign-on et accès basé sur les rôles",
      "Intégration avec les systèmes existants",
      "Hébergement et mises à jour inclus",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  },
  {
    title: "Applications mobiles",
    description:
      "Applications natives et cross-platform pour iOS et Android. Pour les collaborateurs sur le terrain, les techniciens en intervention, ou les clients qui veulent travailler en déplacement.",
    features: [
      "Conception offline-first",
      "Intégration caméra et GPS",
      "Notifications push",
      "Synchronisation transparente avec les systèmes centraux",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Intégrations",
    description:
      "Connexions avec les écosystèmes belges : eID, Peppol, banques, logiciels comptables et services publics. Nous connaissons les standards et les pièges.",
    features: [
      "Facturation électronique Peppol",
      "Authentification eID et itsme",
      "Connexion CODA et SEPA",
      "Exact, Octopus, Yuki, Wings",
    ],
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
  },
];

const process = [
  {
    step: "01",
    title: "Découverte",
    description:
      "Nous écoutons. Votre entreprise, vos processus, vos frustrations avec les outils actuels. Pas de questionnaires — juste une conversation.",
  },
  {
    step: "02",
    title: "Proposition",
    description:
      "Une proposition claire avec périmètre, planning et prix indicatif. Pas de surprises a posteriori. C'est vous qui décidez ce qui est pertinent.",
  },
  {
    step: "03",
    title: "Développement itératif",
    description:
      "Cycles courts avec démonstrations intermédiaires. Vous donnez votre retour, nous adaptons. Livraison continue, pas de lancement big-bang.",
  },
  {
    step: "04",
    title: "Production et accompagnement",
    description:
      "Déploiement avec formation et support. Ensuite, maintenance à long terme et évolutions continues.",
  },
];
---

<BaseLayout
  title="Services — ADM-Concept"
  description="Logiciels sur mesure, plateformes web, applications mobiles et intégrations. De l'analyse à la production et à l'accompagnement à long terme."
>
  <!-- Hero with image -->
  <section class="py-16 lg:py-24 bg-mesh-1 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="inline-block px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-xs font-semibold text-emerald-700 mb-4">
            Services
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Ce que nous construisons,<br />
            et comment nous travaillons.
          </h1>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-xl">
            De la première idée à la production et à la maintenance continue. Nous
            accompagnons votre démarche de digitalisation de A à Z.
          </p>
        </div>
        <div class="lg:col-span-2 relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-emerald-200 to-brand-200 rounded-3xl blur-2xl opacity-50"></div>
          <img
            src="/images/tech-laptop.jpg"
            alt="Travail moderne sur des projets technologiques"
            class="relative w-full h-[320px] object-cover rounded-2xl shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <article class="group p-8 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-xl transition-all duration-300">
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 text-slate-700 flex items-center justify-center mb-6 group-hover:from-brand-100 group-hover:to-brand-200 group-hover:text-brand-700 transition-all">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-3">{service.title}</h3>
              <p class="text-slate-600 leading-relaxed mb-6">{service.description}</p>
              <ul class="space-y-2">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-slate-700">
                    <svg
                      class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 lg:py-32 bg-slate-50/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-purple-50 border border-purple-100 text-xs font-semibold text-purple-700 mb-4">
          Notre méthode
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Quatre phases,<br />
          pas de surprises
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          process.map((phase) => (
            <div class="relative p-8 bg-white rounded-2xl border border-slate-200">
              <div class="text-5xl font-extrabold text-slate-200 mb-4">{phase.step}</div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{phase.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{phase.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA
    title="Quel défi voulons-nous relever ensemble ?"
    description="Commencez par un entretien sans engagement. Nous écoutons, réfléchissons avec vous et vous donnons un conseil honnête — même si c'est pour vous dire que vous n'avez pas besoin de logiciel."
  />
</BaseLayout>
