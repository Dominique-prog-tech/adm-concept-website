---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import BlogHeroBanner from "../../components/BlogHeroBanner.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft && data.lang === "nl");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  date.toLocaleDateString("nl-BE", { day: "numeric", month: "long", year: "numeric" });

// Verkrijg andere posts voor "Lees ook"
const allPosts = (await getCollection("blog", ({ data }) => !data.draft && data.lang === "nl"))
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title={`${post.data.title} — ADM-Concept`}
  description={post.data.description}
  ogImage={post.data.image || "/images/office-workspace.jpg"}
  ogType="article"
  publishedDate={post.data.pubDate}
  author={post.data.author}
>
  <!-- Hero -->
  <section class="py-16 lg:py-20 bg-mesh-1">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1 text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Alle blog-posts
      </a>

      {
        post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6">
            {post.data.tags.map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold rounded-full bg-brand-50 border border-brand-100 text-brand-700">
                {tag}
              </span>
            ))}
          </div>
        )
      }

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
        {post.data.title}
      </h1>

      <div class="mt-6 flex items-center gap-3 text-sm text-slate-600">
        <span class="font-medium text-slate-900">{post.data.author}</span>
        <span>·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {formatDate(post.data.pubDate)}
        </time>
      </div>
    </div>
  </section>

  {
    post.data.bannerColor && (post.data.bannerLogo || post.data.bannerIcon) ? (
      <section class="py-8">
        <div class="max-w-5xl mx-auto px-6 lg:px-8">
          <BlogHeroBanner
            bannerColor={post.data.bannerColor}
            bannerLogo={post.data.bannerLogo}
            bannerIcon={post.data.bannerIcon}
            alt={post.data.title}
          />
        </div>
      </section>
    ) : post.data.image && (
      <section class="py-8">
        <div class="max-w-5xl mx-auto px-6 lg:px-8">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="w-full h-[400px] sm:h-[500px] object-cover rounded-2xl shadow-xl"
            loading="eager"
          />
        </div>
      </section>
    )
  }

  <!-- Article content -->
  <article class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-6 lg:px-8">
      <div class="prose prose-slate prose-lg max-w-none
                  prose-headings:font-bold prose-headings:tracking-tight
                  prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-4
                  prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-3
                  prose-p:text-slate-700 prose-p:leading-relaxed
                  prose-a:text-brand-600 prose-a:no-underline hover:prose-a:underline
                  prose-strong:text-slate-900
                  prose-ul:my-6 prose-li:text-slate-700">
        <Content />
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {
    allPosts.length > 0 && (
      <section class="py-16 lg:py-24 bg-slate-50/60">
        <div class="max-w-7xl mx-auto px-6 lg:px-8">
          <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 mb-8">
            Lees ook
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {allPosts.map((p) => (
              <a
                href={`/blog/${p.id}`}
                class="group flex gap-4 p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-md transition-all"
              >
                <div class="flex-1 min-w-0">
                  <div class="text-xs text-slate-500 mb-2">{formatDate(p.data.pubDate)}</div>
                  <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-brand-600 transition-colors">
                    {p.data.title}
                  </h3>
                  <p class="text-sm text-slate-600 leading-relaxed line-clamp-2">
                    {p.data.description}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CTA />
</BaseLayout>
