---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductCard from "../components/ProductCard.astro";
import CTA from "../components/CTA.astro";

const products = [
  {
    name: "CreditSoft",
    tagline: "Voor professionele kredietmakelaars",
    description:
      "Het alles-in-één platform voor kredietbemiddeling: klantenbeheer, dossiers, bankbeheer, commissies en forecasts in één veilig systeem.",
    features: [
      "Dossiers en bankbeheer (multi-bank)",
      "Commissies met groeperingen en borderellen",
      "Klantportaal voor documentupload",
      "Inkomstenprognoses per kantoor of aanbrenger",
    ],
    href: "/producten/creditsoft",
    externalDocsUrl: "https://docs.creditsoft.be",
    color: "blue" as const,
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
  },
  {
    name: "CleanOps",
    tagline: "Voor rioolreiniging en ruimdiensten",
    description:
      "Alles-in-één software voor ruimdiensten en rioolbedrijven. Planning, werkbonnen, camera-inspecties en facturatie in één platform.",
    features: [
      "Planning & dispatch voor ploegen",
      "Werkbonnen en cameraverslagen",
      "Contracten voor steden en syndicussen",
      "Peppol-facturatie en bankintegratie",
    ],
    href: "/producten/cleanops",
    externalDocsUrl: "https://docs.cleanops.eu",
    color: "teal" as const,
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    name: "Nimble",
    tagline: "Voor projectgebaseerde bedrijven",
    description:
      "ERP voor bouw, installatie en projectuitvoering. Projecten, vorderingsstaten, planning en facturatie — alles wat een projectorganisatie nodig heeft.",
    features: [
      "Projectbeheer met fases",
      "Vorderingsstaten en deelfacturen",
      "Ploegen en tijdsregistratie",
      "Exact Online integratie",
    ],
    href: "/producten/nimble",
    externalDocsUrl: "https://docs.nimble-erp.eu",
    color: "purple" as const,
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
];

const services = [
  {
    title: "Maatwerksoftware",
    description:
      "Bedrijfsspecifieke applicaties die exact uw werkproces volgen. Geen aanpassen aan generieke software — wel software die aanpast aan u.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  },
  {
    title: "Webplatformen",
    description:
      "Moderne web-applicaties voor uw klanten, partners of medewerkers. Veilig, schaalbaar en toegankelijk vanuit elke browser.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  },
  {
    title: "Mobiele toepassingen",
    description:
      "Apps voor iOS en Android die naadloos aansluiten op uw centrale systemen. Voor uw medewerkers in het veld of uw klanten onderweg.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    title: "Integraties",
    description:
      "Koppelingen met eID, Peppol, boekhoudsoftware, bankplatformen en alle systemen die uw bedrijf gebruikt. Alles spreekt met alles.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>`,
  },
];

const principles = [
  {
    title: "Geen standaardpakketten",
    description:
      "Elke organisatie werkt anders. Standaardsoftware dwingt u in een vorm die niet de uwe is. Wij bouwen rond uw proces, niet andersom.",
  },
  {
    title: "Lange-termijn partner",
    description:
      "Software is een investering, geen project. Klanten van het eerste uur draaien nog steeds op onze platformen — en we ontwikkelen mee.",
  },
  {
    title: "Belgische verankering",
    description:
      "Lokaal team, lokale ervaring, lokale wetgeving. Van Peppol tot BTW-aangiftes, van eID tot SEPA Direct Debit — we kennen het ecosysteem.",
  },
  {
    title: "Open en duurzaam",
    description:
      "Uw data blijft uw data. Standaardformaten, open APIs, geen artificiële lock-in. U kiest ons voor de kwaliteit, niet omdat u niet weg kan.",
  },
];
---

<BaseLayout>
  <Hero />

  <!-- Products section -->
  <section class="py-24 lg:py-32 bg-slate-50/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-brand-50 border border-brand-100 text-xs font-semibold text-brand-700 mb-4">
          Onze platformen
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Drie platformen.<br />
          Eén kwaliteits&shy;belofte.
        </h2>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Naast maatwerk hebben we drie gespecialiseerde platformen ontwikkeld voor
          specifieke sectoren. Bewezen oplossingen die u snel productief krijgen.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {products.map((product) => <ProductCard {...product} />)}
      </div>
    </div>
  </section>

  <!-- Services section -->
  <section class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-xs font-semibold text-emerald-700 mb-4">
          Onze diensten
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Wat we bouwen
        </h2>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Van mobiele toepassingen tot integratie-projecten met overheidsdiensten:
          wij bouwen software die uw bedrijf vooruit brengt.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          services.map((service) => (
            <div class="group p-8 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 transition-all hover:shadow-lg">
              <div class="w-12 h-12 rounded-xl bg-slate-100 text-slate-700 flex items-center justify-center mb-5 group-hover:bg-brand-100 group-hover:text-brand-700 transition-colors">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-3">{service.title}</h3>
              <p class="text-slate-600 leading-relaxed">{service.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Principles section -->
  <section class="py-24 lg:py-32 bg-slate-50/50">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-purple-50 border border-purple-100 text-xs font-semibold text-purple-700 mb-4">
          Waar we voor staan
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Onze principes
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {
          principles.map((principle, index) => (
            <div class="flex gap-6">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-slate-900 text-white flex items-center justify-center font-bold text-lg">
                0{index + 1}
              </div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">{principle.title}</h3>
                <p class="text-slate-600 leading-relaxed">{principle.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
