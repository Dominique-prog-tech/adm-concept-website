---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const phases = [
  {
    step: "01",
    title: "Verkenning",
    duration: "1 tot 2 weken",
    description:
      "We luisteren eerst. Geen vragenlijsten, gewoon een vrijblijvend gesprek over wat u wil bereiken, wat er nu niet werkt en waar de pijn zit.",
    weDo: [
      "Verkennend gesprek (1-2 uur, online of bij u)",
      "Eerste inschatting van scope en complexiteit",
      "Eerlijk advies — ook als dat is dat u geen nieuwe software nodig heeft",
    ],
    weAsk: [
      "Tijd om uw situatie eerlijk uit te leggen",
      "Indien beschikbaar: voorbeelden van uw huidige werkwijze",
    ],
  },
  {
    step: "02",
    title: "Analyse & voorstel",
    duration: "1 tot 3 weken",
    description:
      "Op basis van de verkenning duiken we dieper: welke processen, welke gebruikers, welke koppelingen? We leveren een helder voorstel met scope, planning en richtprijs.",
    weDo: [
      "Workshop(s) met u en uw sleutel-medewerkers",
      "Architectuur en data-model uittekenen",
      "Concreet voorstel: scope, planning, prijsmodel",
      "Risicoanalyse en alternatieven",
    ],
    weAsk: [
      "Toegang tot mensen die het proces dagelijks gebruiken",
      "Beslissingsbevoegdheid bij de tafel",
    ],
  },
  {
    step: "03",
    title: "Iteratieve bouw",
    duration: "2 tot 6 maanden",
    description:
      "Korte sprints met tussentijdse demo's. U geeft feedback, wij passen aan. Geen big-bang-launch — alles wordt stap voor stap zichtbaar en bruikbaar.",
    weDo: [
      "Sprints van 2-3 weken met concrete deliverables",
      "Wekelijkse of tweewekelijkse demo's",
      "Transparante voortgangsrapportering en backlog",
      "Code en infrastructuur volledig bij u — geen vendor lock-in",
    ],
    weAsk: [
      "1 tot 2 uur per week voor feedback en validatie",
      "Eén centrale aanspreekpersoon aan uw kant",
    ],
  },
  {
    step: "04",
    title: "Acceptatie & lancering",
    duration: "2 tot 4 weken",
    description:
      "Voor de productiegang testen we samen, leiden uw team op en plannen we een stabiele roll-out. Geen verrassingen op live-dag.",
    weDo: [
      "User Acceptance Testing met scenario's uit uw praktijk",
      "Opleidingssessies voor eindgebruikers",
      "Documentatie en handleiding",
      "Migratie van bestaande data (indien van toepassing)",
      "Go-live met directe ondersteuning",
    ],
    weAsk: [
      "Beschikbaarheid van eindgebruikers voor opleiding",
      "Tijd voor een parallelle testfase",
    ],
  },
  {
    step: "05",
    title: "Begeleiding & doorontwikkeling",
    duration: "Doorlopend",
    description:
      "Een softwareproject eindigt niet bij livegang. We bieden support, lossen onverwachte issues op en helpen u doorgroeien naar nieuwe functionaliteit naargelang uw bedrijf evolueert.",
    weDo: [
      "Reactieve support volgens een SLA op maat",
      "Periodiek onderhoud en updates",
      "Doorontwikkeling op basis van uw veranderende noden",
      "Updates van onderliggende technologie en beveiliging",
    ],
    weAsk: [
      "Open communicatie over wat wel én niet werkt in de praktijk",
    ],
  },
];

const principles = [
  {
    title: "Geen verrassingen op de factuur",
    description:
      "Heldere scope vooraf en een transparante meerwerk-procedure. U krijgt nooit een factuur die u niet zag aankomen.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: "U bent eigenaar",
    description:
      "De broncode, data en infrastructuur zijn van u. Geen vendor lock-in: u kan altijd weg, of een andere partij laten verder bouwen.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
  },
  {
    title: "Sinds 1997",
    description:
      "28 jaar ervaring met Belgische bedrijven en hun specifieke uitdagingen: Peppol, eID, regelgeving, integraties met lokale boekhoudpakketten.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: "Geen tussenlagen",
    description:
      "U spreekt rechtstreeks met de mensen die uw oplossing bouwen — geen account manager als boodschapper, geen telefoonspel.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
  },
  {
    title: "Iteratief, niet big-bang",
    description:
      "Korte cycli betekenen vroege feedback en minder risico. U ziet uw oplossing groeien in plaats van te wachten op een mysterieuze livegang.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
  },
  {
    title: "Eerlijk advies",
    description:
      "Soms is geen nieuwe software de juiste oplossing — een aanpassing aan uw bestaande tool of een procesverandering volstaat. Wij zeggen het.",
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  },
];

const faq = [
  {
    question: "Werken jullie met vaste prijs of dagprijs?",
    answer:
      "Beide, afhankelijk van de aard van het project. Voor scherp gedefinieerde scope's werken we met een vaste prijs. Voor open uitdagingen met onzekere scope gebruiken we een dagprijs met cap. We bespreken vooraf welk model past bij uw situatie.",
  },
  {
    question: "Hoe lang duurt een gemiddeld maatwerkproject?",
    answer:
      "Een typische maatwerktoepassing is 3 tot 6 maanden tot een eerste live versie, gevolgd door continue doorontwikkeling. Kleinere uitbreidingen op bestaande software gaan vaak in weken. We geven steeds een realistische inschatting na de analysefase.",
  },
  {
    question: "Wat als de scope verschuift tijdens het project?",
    answer:
      "Onze iteratieve aanpak vangt dit op. Korte cycli betekenen dat we elke 2-3 weken her-evalueren en bijsturen. Significante scope-wijzigingen bespreken we met u — met heldere impact op planning en budget, geen verrassingen.",
  },
  {
    question: "Wie bezit de code en data?",
    answer:
      "U. Volledig. Bij oplevering krijgt u de broncode, alle data en de deploy-instructies. We leveren bedrijfskritische systemen — eigendom is essentieel. Geen licentiestructuur, geen lock-in.",
  },
  {
    question: "Wat met hosting en onderhoud na livegang?",
    answer:
      "Beide opties zijn mogelijk. We hosten zelf (managed) of we leveren uw oplossing zodat ze bij u of een door u gekozen hosting-partij draait. De keuze hangt af van uw voorkeur, schaal en compliance-eisen.",
  },
  {
    question: "Welke technologieën gebruiken jullie?",
    answer:
      "We kiezen op basis van uw situatie en bestaande IT-landschap. Geen religie rond één framework — wel een sterke voorkeur voor proven, langetermijn stabiele stacks: .NET, Delphi, moderne web-frameworks (Astro, React), Node.js, en native mobile (iOS/Android) wanneer nodig.",
  },
];

// JSON-LD: FAQPage — laat Google de vragen tonen als rich snippet
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="Werkwijze: 5 fasen voor maatwerkprojecten — ADM-Concept"
  description="Hoe een maatwerk-softwareproject bij ADM-Concept verloopt: van verkennend gesprek tot productie en jarenlange doorontwikkeling. Vijf fasen, geen verrassingen."
>
  <!-- Hero -->
  <section class="py-16 lg:py-24 bg-mesh-1 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 items-center">
        <div class="lg:col-span-3">
          <div class="inline-block px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-xs font-semibold text-indigo-700 mb-4">
            Werkwijze
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Geen black box.<br />
            Geen verrassingen.
          </h1>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-xl">
            Hoe een softwareproject bij ADM-Concept verloopt — van eerste
            verkennend gesprek tot productie en jaren doorontwikkeling. In vijf
            fasen, met heldere afspraken in elke fase.
          </p>
        </div>
        <div class="lg:col-span-2 relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-indigo-200 to-brand-200 rounded-3xl blur-2xl opacity-50"></div>
          <img
            src="/images/team-collaboration.jpg"
            alt="Samenwerking aan een maatwerkproject"
            class="relative w-full h-[320px] object-cover rounded-2xl shadow-2xl"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 5 phases -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="inline-block px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-xs font-semibold text-indigo-700 mb-4">
          De vijf fasen
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Van eerste gesprek tot doorlopende evolutie
        </h2>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          In elke fase weet u wat we doen, wat we van u verwachten en
          ongeveer hoe lang het duurt. Geen verrassingen.
        </p>
      </div>

      <div class="space-y-8">
        {phases.map((phase, idx) => (
          <article class="relative p-8 lg:p-10 bg-white border border-slate-200 rounded-2xl hover:border-indigo-200 hover:shadow-xl transition-all">
            <div class="grid lg:grid-cols-12 gap-8">
              <div class="lg:col-span-4">
                <div class="text-6xl font-extrabold text-indigo-100 mb-2">{phase.step}</div>
                <h3 class="text-2xl font-bold text-slate-900 mb-2">{phase.title}</h3>
                <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-slate-100 text-xs font-semibold text-slate-600">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {phase.duration}
                </div>
                <p class="mt-4 text-slate-600 leading-relaxed">{phase.description}</p>
              </div>

              <div class="lg:col-span-4">
                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-3">Wat wij doen</h4>
                <ul class="space-y-2">
                  {phase.weDo.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-slate-700">
                      <svg class="w-4 h-4 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="lg:col-span-4">
                <h4 class="text-xs font-bold uppercase tracking-wider text-slate-500 mb-3">Wat we van u vragen</h4>
                <ul class="space-y-2">
                  {phase.weAsk.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-slate-700">
                      <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-xs font-semibold text-indigo-700 mb-4">
          Wat ons onderscheidt
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Zes principes die elke beslissing sturen
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {principles.map((p) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl">
            <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-700 flex items-center justify-center mb-4">
              <Fragment set:html={p.icon} />
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{p.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-xs font-semibold text-indigo-700 mb-4">
          Veelgestelde vragen
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
          Praktische vragen die elke prospect stelt
        </h2>
      </div>

      <div class="space-y-4">
        {faq.map((item) => (
          <details class="group bg-white border border-slate-200 rounded-xl">
            <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer list-none">
              <h3 class="text-base font-semibold text-slate-900">{item.question}</h3>
              <svg class="w-5 h-5 text-slate-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-slate-600 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Klaar voor een eerste verkennend gesprek?"
    description="We bekijken samen waar u staat en geven u een eerlijk advies. Vrijblijvend, en als we niet de juiste partij zijn — dan zeggen we dat ook."
  />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
