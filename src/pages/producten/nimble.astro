---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import NimbleMockup from "../../components/mockups/NimbleMockup.astro";

const modules = [
  { title: "Projecten", description: "Projectfases, mijlpalen, deliverables — overzicht over al uw lopende werven." },
  { title: "Vorderingsstaten", description: "Periodieke deelfacturen op basis van uitvoeringspercentage." },
  { title: "Planning", description: "Plan ploegen en materiaal per project. Visueel overzicht in agenda en kalender." },
  { title: "Offertes", description: "Offertes opmaken, opvolgen en omzetten naar projecten." },
  { title: "Financieel", description: "Verkoopdashboard, facturen, herinneringen, aankoopfacturen." },
  { title: "Integraties", description: "Exact Online, Peppol, tijdsregistratie, materiaalbeheer." },
];

const doelgroepen = [
  "Bouwbedrijven en aannemers",
  "Installatiebedrijven (elektriciteit, sanitair, HVAC)",
  "Schrijnwerkerijen en metaalbouw",
  "Projectaannemers",
  "Studiebureaus en consultants",
  "Algemene KMO's met projectwerking",
];
---

<BaseLayout
  title="Nimble — ERP voor projectgebaseerde bedrijven"
  description="Projectbeheer, vorderingsstaten, planning en facturatie voor bouw, installatie en projectuitvoering."
  ogImage="/images/og/nimble.png"
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-purple-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/products/nimble.svg"
              alt="Nimble logo"
              class="w-20 h-20 rounded-2xl shadow-xl shadow-slate-900/10"
              width="80"
              height="80"
            />
            <span class="text-sm font-semibold text-purple-700">PLATFORM</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            Nimble
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            ERP voor wie projectmatig werkt — bouw, installatie, uitvoering.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Van offerte tot eindafrekening — Nimble begeleidt het volledige
            projectproces. Met functies die projectbedrijven écht nodig hebben:
            vorderingsstaten, materiaalbeheer, ploegenplanning, tijdsregistratie.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://www.nimble-erp.eu" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-purple-600 hover:bg-purple-700 rounded-xl transition-all shadow-lg">
              Bezoek nimble-erp.eu
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Vraag een demo
            </a>
            <a href="https://docs.nimble-erp.eu" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-700 hover:text-slate-900 rounded-xl transition-all">
              Documentatie
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <NimbleMockup />
        </div>
      </div>
    </div>
  </section>

  <!-- Doelgroep -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-purple-50 border border-purple-100 text-xs font-semibold text-purple-700 mb-4">
          Voor wie
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Gebouwd voor KMO's die projectmatig werken
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          Nimble is compact ERP voor kleinere KMO's — geen overkill van een grootschalig systeem, wel net de functies die projectorganisaties dagelijks nodig hebben.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {doelgroepen.map((d) => (
          <div class="flex items-center gap-3 p-4 bg-white border border-slate-200 rounded-xl">
            <svg class="w-5 h-5 text-purple-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-800 font-medium">{d}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-purple-50 border border-purple-100 text-xs font-semibold text-purple-700 mb-4">
          Functies
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Alles wat een projectorganisatie nodig heeft
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-purple-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Klaar voor projectmanagement op niveau?"
    description="Boek een vrijblijvende demo en ontdek hoe Nimble uw projectflow versimpelt — van offerte tot oplevering."
    buttonText="Plan een demo"
  />
</BaseLayout>
