---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import CreditSoftMockup from "../../components/mockups/CreditSoftMockup.astro";

const modules = [
  {
    title: "Klantenbeheer",
    description:
      "Centrale klantenfiches met GDPR-conforme opslag. Alle informatie van uw klanten op één veilige plek.",
  },
  {
    title: "Dossierbeheer",
    description:
      "Meerdere dossiers per klant met statustracking. Volg de levenscyclus van elk dossier — van eerste contact tot afsluiting.",
  },
  {
    title: "Documentenbeheer",
    description:
      "Automatische checklists per dossier-type. Klanten uploaden documenten via hun eigen portaal — geen mailwisseling meer.",
  },
  {
    title: "Bankbeheer",
    description:
      "Dien dossiers tegelijk bij meerdere banken in. Volg per bank de status, communicatie en beslissingen.",
  },
  {
    title: "Commissies",
    description:
      "Automatische berekening en spreiding. Borderellen genereren, commissieschema's per tussenpersoon, controle en validatie.",
  },
  {
    title: "Forecasts",
    description:
      "Inkomstenprognoses per kantoor, aanbrenger of dossier. Zicht op uw cashflow voor de komende maanden.",
  },
  {
    title: "Klantportaal",
    description:
      "Klanten zien hun dossierstatus en kunnen documenten uploaden. Transparantie zonder dat u uren aan de telefoon hangt.",
  },
  {
    title: "Groeperingen",
    description:
      "Voor kredietkantoren en samenwerkingsverbanden: centrale controle en transparante verdeling van dossiers en commissies.",
  },
];

const doelgroepen = [
  {
    title: "Zelfstandige kredietmakelaars",
    description: "Voor professioneel beheer zonder administratieve chaos.",
  },
  {
    title: "Kredietkantoren",
    description: "Voor volledig inzicht in dossiers en inkomsten.",
  },
  {
    title: "Groeperingen",
    description: "Voor centrale controle en transparante verdeling.",
  },
];
---

<BaseLayout
  title="CreditSoft — Platform voor professionele kredietmakelaars"
  description="Het alles-in-één platform voor kredietbemiddeling: klantenbeheer, dossiers, bankbeheer, commissies en forecasts. Voor zelfstandige makelaars, kantoren en groeperingen."
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <img
              src="/images/products/creditsoft.svg"
              alt="CreditSoft logo"
              class="w-20 h-20 rounded-2xl shadow-xl shadow-slate-900/10"
              width="80"
              height="80"
            />
            <span class="text-sm font-semibold text-blue-700">PLATFORM</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            CreditSoft
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            Het alles-in-één platform voor professionele kredietmakelaars.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Centraliseer het volledige kredietbemiddelingsproces: klantenbeheer,
            dossierverwerking, documentopslag, commissieberekening en
            inkomstprognoses in één veilig systeem. Ontwikkeld in samenwerking
            met echte kredietmakelaars.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://www.creditsoft.be" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-lg">
              Bezoek creditsoft.be
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Vraag een demo
            </a>
            <a href="https://docs.creditsoft.be" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-700 hover:text-slate-900 rounded-xl transition-all">
              Documentatie
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <CreditSoftMockup />
        </div>
      </div>
    </div>
  </section>

  <!-- Doelgroep -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-4">
          Voor wie
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Drie schalen, één platform
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {doelgroepen.map((d) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{d.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{d.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <div class="inline-block px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-xs font-semibold text-blue-700 mb-4">
          Functies
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Alles wat een kredietmakelaar nodig heeft
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-blue-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- USP block -->
  <section class="py-16 lg:py-24 bg-slate-50/60">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="p-10 bg-white border border-slate-200 rounded-2xl">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Waarom CreditSoft?</h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Specialisatie in kredietsector</strong> — geen generieke ERP, wel software gemaakt voor en met kredietmakelaars.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Ingebouwde commissie- en groeperingsfunctionaliteiten</strong> — geen workarounds nodig.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-slate-700"><strong class="text-slate-900">Ontwikkeld in samenwerking met echte kredietmakelaars</strong> — feedback uit de praktijk vormt elke versie.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <CTA
    title="Interesse in CreditSoft?"
    description="We tonen u graag in een online demo hoe het platform in uw kantoor zou werken. Vrijblijvend en zonder verkooppraat."
    buttonText="Plan een demo"
  />
</BaseLayout>
