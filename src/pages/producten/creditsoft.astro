---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import DashboardMockup from "../../components/DashboardMockup.astro";

const modules = [
  { title: "Kredietdossiers", description: "Complete dossierbeheer van aanmaak tot afsluiting. Workflow-statussen, documenten, opvolging." },
  { title: "CRM", description: "Bedrijven, contacten, notarissen, schatters, immokantoren — alle relaties op één plek." },
  { title: "Commissiebeheer", description: "Schema's per tussenpersoon, automatische berekening, controle en validatie." },
  { title: "LOA & SSV", description: "Volledige opvolging van Letters of Acceptance en vergelijkingen." },
  { title: "Boekhouding", description: "Boekjaren, dagboeken, bankverrichtingen — boekhouding direct in het platform." },
  { title: "Peppol", description: "E-facturatie ingebouwd. Verzending en ontvangst via het Europese netwerk." },
];
---

<BaseLayout
  title="CreditSoft — Platform voor kredietmakelaars"
  description="Volledig platform voor kredietbemiddeling: dossierbeheer, CRM, commissieadministratie en opvolging na akte."
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-blue-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-blue-500 to-blue-700 text-white flex items-center justify-center shadow-lg">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <span class="text-sm font-semibold text-blue-700">PLATFORM</span>
          </div>
          <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
            CreditSoft
          </h1>
          <p class="mt-3 text-xl font-medium text-slate-600">
            Het complete platform voor de Belgische kredietmakelaar.
          </p>
          <p class="mt-6 text-lg text-slate-600 leading-relaxed">
            Van eerste klantcontact tot uitbetaling na akte — CreditSoft begeleidt
            het volledige kredietproces. Met sectorkennis ingebakken: LOA, SSV,
            commissieschema's, FSMA-conformiteit.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-xl transition-all shadow-lg">
              Vraag een demo
            </a>
            <a href="https://docs.creditsoft.be" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
              Bekijk de documentatie
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <DashboardMockup variant="blue" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Alles wat een kredietmakelaar nodig heeft
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-blue-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Interesse in CreditSoft?"
    description="We tonen u graag in een online demo hoe het platform in uw kantoor zou werken. Vrijblijvend en zonder verkooppraat."
    buttonText="Plan een demo"
  />
</BaseLayout>
