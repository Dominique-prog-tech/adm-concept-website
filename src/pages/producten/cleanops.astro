---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";

const modules = [
  { title: "Werkzaamheden", description: "Contracten, automatische opdrachten-generatie, planning per ploeg en voertuig." },
  { title: "CRM", description: "Klanten, leveranciers, medewerkers met verloven en saldi." },
  { title: "Attesten", description: "Wettelijke verwerkingsattesten met producten en verwerkingsbedrijven." },
  { title: "Facturatie", description: "Offertes, facturen, rappels, openstaande posten, schuldbemiddelingen." },
  { title: "Boekhouding", description: "Volledige boekhouding inclusief bankverrichtingen en klantenbalans." },
  { title: "Peppol", description: "E-facturatie via Peppol. Voldoet aan de Belgische verplichting." },
];
---

<BaseLayout
  title="CleanOps — Platform voor schoonmaak- en afvalverwerking"
  description="Planning, opdrachten, attesten en facturatie voor schoonmaak- en verwerkingsbedrijven."
>
  <section class="py-16 lg:py-24 bg-gradient-to-br from-teal-50 to-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-teal-500 to-teal-700 text-white flex items-center justify-center shadow-lg">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
          </div>
          <span class="text-sm font-semibold text-teal-700">PLATFORM</span>
        </div>
        <h1 class="text-5xl lg:text-6xl font-extrabold tracking-tight text-slate-900 leading-tight">
          CleanOps
        </h1>
        <p class="mt-3 text-xl font-medium text-slate-600">
          Het centrale platform voor schoonmaak- en afvalverwerkingsbedrijven.
        </p>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed">
          Beheer contracten, plan opdrachten, registreer attesten, factureer
          met Peppol. Eén platform, sectorkennis ingebakken, klaar voor de
          Belgische wetgeving rond afvalverwerking.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-slate-900 hover:bg-slate-800 rounded-xl transition-all shadow-lg">
            Vraag een demo
          </a>
          <a href="https://docs.cleanops.eu" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-slate-900 bg-white hover:bg-slate-50 border border-slate-200 rounded-xl transition-all">
            Bekijk de documentatie
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-slate-900">
          Volledig schoonmaakbedrijf-management
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {modules.map((m) => (
          <div class="p-6 bg-white border border-slate-200 rounded-2xl hover:border-teal-200 hover:shadow-md transition-all">
            <h3 class="text-lg font-bold text-slate-900 mb-2">{m.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{m.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA
    title="Klaar om uw schoonmaakbedrijf te digitaliseren?"
    description="We tonen u in een vrijblijvende demo hoe CleanOps uw planning, facturatie en attesten op één plek samenbrengt."
    buttonText="Plan een demo"
  />
</BaseLayout>
