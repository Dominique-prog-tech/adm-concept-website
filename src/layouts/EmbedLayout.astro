---
// Kale layout zonder site-header/footer, bedoeld om in een iframe te tonen
// (bv. binnen de desktop-applicaties als ingebed support-tabblad).
// Laadt wel de globale Tailwind-stijlen en het Inter-lettertype zodat de
// ingebedde pagina er identiek uitziet als de rest van de site.
import "../styles/global.css";

interface Props {
  title?: string;
  lang?: string;
}

const { title = "Support — ADM-Concept", lang = "nl-BE" } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Ingebedde pagina: niet indexeren -->
    <meta name="robots" content="noindex, nofollow" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <slot />
  </body>
</html>
