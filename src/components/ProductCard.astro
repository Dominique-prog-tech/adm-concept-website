---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  name: string;
  tagline: string;
  description: string;
  features: string[];
  href: string;
  externalDocsUrl?: string;
  color: "blue" | "teal" | "purple";
  icon: string;
}

const { name, tagline, description, features, href, externalDocsUrl, color, icon } = Astro.props;

const colorClasses = {
  blue: "from-blue-500 to-blue-700 group-hover:from-blue-600 group-hover:to-blue-800",
  teal: "from-teal-500 to-teal-700 group-hover:from-teal-600 group-hover:to-teal-800",
  purple: "from-purple-500 to-purple-700 group-hover:from-purple-600 group-hover:to-purple-800",
};

const borderColorClasses = {
  blue: "hover:border-blue-300",
  teal: "hover:border-teal-300",
  purple: "hover:border-purple-300",
};
---

<article
  class={`group relative bg-white border border-slate-200 ${borderColorClasses[color]} rounded-2xl p-8 transition-all hover:shadow-xl hover:-translate-y-1 duration-300`}
>
  <!-- Icon -->
  <div
    class={`w-14 h-14 rounded-xl bg-gradient-to-br ${colorClasses[color]} text-white flex items-center justify-center mb-6 shadow-lg shadow-slate-900/5 transition-all`}
  >
    <Fragment set:html={icon} />
  </div>

  <h3 class="text-2xl font-bold text-slate-900 mb-1">{name}</h3>
  <p class="text-sm font-medium text-slate-500 mb-4">{tagline}</p>

  <p class="text-slate-600 mb-6 leading-relaxed">{description}</p>

  <ul class="space-y-2 mb-8">
    {
      features.map((feature) => (
        <li class="flex items-start gap-2 text-sm text-slate-700">
          <svg
            class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{feature}</span>
        </li>
      ))
    }
  </ul>

  <div class="flex flex-wrap gap-3 pt-4 border-t border-slate-100">
    <a
      href={href}
      class="inline-flex items-center gap-1 text-sm font-semibold text-slate-900 hover:text-brand-600 transition-colors"
    >
      {t("product.moreInfo")}
      <svg
        class="w-4 h-4 transition-transform group-hover:translate-x-0.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
    {
      externalDocsUrl && (
        <a
          href={externalDocsUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700 transition-colors"
        >
          {t("product.documentation")}
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
            />
          </svg>
        </a>
      )
    }
  </div>
</article>
