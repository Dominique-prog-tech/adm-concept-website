---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  variant?: "blue" | "teal" | "purple";
}

const { variant = "blue" } = Astro.props;

const colorMap = {
  blue: {
    primary: "#3b82f6",
    light: "#dbeafe",
    accent: "#2563eb",
  },
  teal: {
    primary: "#14b8a6",
    light: "#ccfbf1",
    accent: "#0d9488",
  },
  purple: {
    primary: "#a855f7",
    light: "#f3e8ff",
    accent: "#9333ea",
  },
};

const c = colorMap[variant];
---

<div class="relative">
  <!-- Decorative blob behind -->
  <div
    class="absolute -inset-8 bg-gradient-to-br from-brand-500/20 via-purple-500/10 to-blue-500/20 rounded-3xl blur-3xl"
  >
  </div>

  <!-- Floating mini stat cards -->
  <div
    class="absolute -top-6 -left-6 w-44 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up"
  >
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <div>
        <div class="text-xs text-slate-500">{t("mockup.dossiersApproved")}</div>
        <div class="text-lg font-bold text-slate-900">+127</div>
      </div>
    </div>
  </div>

  <div
    class="absolute -bottom-4 -right-4 w-52 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up-delay-2"
  >
    <div class="text-xs text-slate-500 mb-2">{t("mockup.revenueMonth")}</div>
    <div class="text-2xl font-bold text-slate-900">€ 47.230</div>
    <div class="mt-2 flex items-end gap-1 h-6">
      {[40, 60, 35, 75, 50, 90, 65].map((h) => (
        <div
          class={`flex-1 rounded-t`}
          style={`height: ${h}%; background: ${c.primary}`}
        />
      ))}
    </div>
  </div>

  <!-- Main browser mockup -->
  <div
    class="relative rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden"
  >
    <!-- Browser chrome -->
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-100 border-b border-slate-200">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
      </div>
      <div
        class="flex-1 mx-4 px-3 py-1 text-xs text-slate-500 bg-white rounded-md border border-slate-200"
      >
        adm-concept.be
      </div>
    </div>

    <!-- Content area -->
    <div class="flex">
      <!-- Sidebar -->
      <div class="w-44 bg-slate-50 border-r border-slate-200 p-4 space-y-2">
        <div class="flex items-center gap-2 mb-4">
          <div
            class="w-7 h-7 rounded-lg flex items-center justify-center text-white text-xs font-bold"
            style={`background: ${c.primary}`}
          >
            AC
          </div>
          <div class="text-xs font-semibold text-slate-700">ADM</div>
        </div>
        <div class="space-y-1.5">
          {[1, 2, 3, 4, 5, 6].map((i) => (
            <div
              class={`h-2.5 rounded ${i === 2 ? '' : 'bg-slate-200'}`}
              style={i === 2 ? `background: ${c.primary}; width: ${[70, 100, 60, 85, 50, 75][i-1]}%` : `width: ${[70, 100, 60, 85, 50, 75][i-1]}%`}
            />
          ))}
        </div>
      </div>

      <!-- Main content -->
      <div class="flex-1 p-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <div class="h-3 bg-slate-200 rounded w-24 mb-2"></div>
            <div class="h-2 bg-slate-100 rounded w-32"></div>
          </div>
          <div
            class="px-3 py-1.5 rounded-md text-xs font-medium text-white"
            style={`background: ${c.primary}`}
          >
            {t("mockup.new")}
          </div>
        </div>

        <!-- Stats row -->
        <div class="grid grid-cols-3 gap-3 mb-6">
          {[1, 2, 3].map((i) => (
            <div class="p-3 rounded-lg border border-slate-200">
              <div class="h-2 bg-slate-200 rounded w-12 mb-2"></div>
              <div class="h-5 bg-slate-300 rounded w-16"></div>
            </div>
          ))}
        </div>

        <!-- Table -->
        <div class="space-y-2">
          {[
            { highlight: true },
            { highlight: false },
            { highlight: false },
            { highlight: false },
          ].map((row) => (
            <div class="flex items-center gap-3 p-2 rounded-lg" style={row.highlight ? `background: ${c.light}` : ''}>
              <div class="w-7 h-7 rounded-full bg-slate-200"></div>
              <div class="flex-1 space-y-1">
                <div class="h-2 bg-slate-300 rounded w-3/4"></div>
                <div class="h-1.5 bg-slate-200 rounded w-1/2"></div>
              </div>
              <div class="w-12 h-2 bg-slate-200 rounded"></div>
              <div
                class="w-2 h-2 rounded-full"
                style={`background: ${row.highlight ? c.primary : '#cbd5e1'}`}
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>
