---
const navItems = [
  { label: "Producten", href: "/producten" },
  { label: "Diensten", href: "/diensten" },
  { label: "Over ons", href: "/over-ons" },
  { label: "Contact", href: "/contact" },
];
---

<header
  class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="ADM-Concept homepage">
        <img
          src="/images/logo.png"
          alt="ADM-Concept"
          class="h-9 w-auto transition-transform group-hover:scale-105"
          width="36"
          height="36"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-slate-700 hover:text-brand-600 transition-colors"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- CTA + mobile menu trigger -->
      <div class="flex items-center gap-3">
        <a
          href="/contact"
          class="hidden sm:inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-white bg-slate-900 hover:bg-slate-800 rounded-lg transition-colors shadow-sm hover:shadow-md"
        >
          Vraag offerte
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>

        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 text-slate-700 hover:text-slate-900"
          aria-label="Menu openen"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-slate-200">
      <nav class="flex flex-col gap-3">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-slate-700 hover:text-brand-600 transition-colors py-2"
            >
              {item.label}
            </a>
          ))
        }
        <a
          href="/contact"
          class="mt-2 inline-flex items-center justify-center gap-1 px-4 py-2 text-sm font-medium text-white bg-slate-900 hover:bg-slate-800 rounded-lg transition-colors"
        >
          Vraag offerte
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
