---
import { getLangFromUrl, useTranslations } from "../../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Mockup specifiek voor CreditSoft: kredietdossier-overzicht
const dossiers = [
  { ref: "KD-2026-0142", klant: t("cs.client1"), bedrag: "€ 285.000", status: t("cs.statusApproved"), statusColor: "emerald" },
  { ref: "KD-2026-0141", klant: t("cs.client2"), bedrag: "€ 145.000", status: t("cs.statusInProgress"), statusColor: "amber" },
  { ref: "KD-2026-0140", klant: t("cs.client3"), bedrag: "€ 520.000", status: t("cs.statusSubmitted"), statusColor: "blue" },
  { ref: "KD-2026-0139", klant: t("cs.client4"), bedrag: "€ 198.500", status: t("cs.statusApproved"), statusColor: "emerald" },
];

const tabs = [t("cs.tabAll"), t("cs.tabInProgress"), t("cs.tabSubmitted"), t("cs.tabApproved")];
---

<div class="relative">
  <div class="absolute -inset-8 bg-gradient-to-br from-blue-500/20 via-blue-400/10 to-cyan-500/20 rounded-3xl blur-3xl"></div>

  <!-- Floating LOA badge -->
  <div class="absolute -top-6 -left-6 w-44 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up">
    <div class="text-xs text-slate-500 mb-1">{t("cs.loaRunning")}</div>
    <div class="flex items-baseline gap-2">
      <div class="text-2xl font-bold text-slate-900">8</div>
      <div class="text-xs text-amber-600 font-medium">{t("cs.loaExpiring")}</div>
    </div>
  </div>

  <!-- Floating commissie badge -->
  <div class="absolute -bottom-4 -right-4 w-52 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up-delay-2">
    <div class="text-xs text-slate-500 mb-2">{t("cs.commissionsMonth")}</div>
    <div class="text-2xl font-bold text-slate-900">€ 23.847</div>
    <div class="mt-2 flex items-center gap-2">
      <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
        <div class="h-full bg-blue-500 rounded-full" style="width: 68%"></div>
      </div>
      <span class="text-xs text-slate-500">68%</span>
    </div>
  </div>

  <!-- Main browser mockup -->
  <div class="relative rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
    <!-- Browser chrome -->
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-100 border-b border-slate-200">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
      </div>
      <div class="flex-1 mx-4 px-3 py-1 text-xs text-slate-500 bg-white rounded-md border border-slate-200">{t("cs.urlPath")}</div>
    </div>

    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h3 class="text-base font-bold text-slate-900">{t("cs.heading")}</h3>
        <p class="text-xs text-slate-500">{t("cs.activeFiles")}</p>
      </div>
      <div class="px-3 py-1.5 rounded-md text-xs font-semibold text-white bg-blue-600">{t("cs.newFile")}</div>
    </div>

    <!-- Tabs -->
    <div class="px-6 pt-3 flex gap-1 border-b border-slate-100 text-xs">
      {tabs.map((tab, i) => (
        <div class={`px-3 py-2 ${i === 0 ? 'border-b-2 border-blue-600 text-blue-700 font-semibold' : 'text-slate-500'}`}>{tab}</div>
      ))}
    </div>

    <!-- Table -->
    <div class="divide-y divide-slate-100">
      {dossiers.map((d) => (
        <div class="px-6 py-3 flex items-center gap-4 hover:bg-slate-50">
          <div class="flex-1 min-w-0">
            <div class="text-xs font-mono text-slate-400">{d.ref}</div>
            <div class="text-sm font-medium text-slate-900 truncate">{d.klant}</div>
          </div>
          <div class="text-sm font-semibold text-slate-900">{d.bedrag}</div>
          <div class={`px-2 py-0.5 text-xs font-medium rounded-full ${
            d.statusColor === 'emerald' ? 'bg-emerald-50 text-emerald-700' :
            d.statusColor === 'amber' ? 'bg-amber-50 text-amber-700' :
            'bg-blue-50 text-blue-700'
          }`}>
            {d.status}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
