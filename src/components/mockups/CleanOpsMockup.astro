---
// Mockup specifiek voor CleanOps: planning-overzicht
const opdrachten = [
  { tijd: "08:00", klant: "Residentie Zonnehof", adres: "Gent", ploeg: "A", color: "teal" },
  { tijd: "10:30", klant: "Kantoor De Brug", adres: "Brugge", ploeg: "B", color: "blue" },
  { tijd: "13:00", klant: "Industriepark Noord", adres: "Antwerpen", ploeg: "A", color: "teal" },
  { tijd: "15:30", klant: "Restaurant Bellini", adres: "Mechelen", ploeg: "C", color: "purple" },
];

const days = ["Ma 26", "Di 27", "Wo 28", "Do 29", "Vr 30"];
---

<div class="relative">
  <div class="absolute -inset-8 bg-gradient-to-br from-teal-500/20 via-emerald-400/10 to-cyan-500/20 rounded-3xl blur-3xl"></div>

  <!-- Floating attest-badge -->
  <div class="absolute -top-6 -left-6 w-44 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up">
    <div class="flex items-center gap-2 mb-1">
      <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
      <div class="text-xs text-slate-500">Attesten conform</div>
    </div>
    <div class="text-2xl font-bold text-slate-900">142</div>
    <div class="text-xs text-slate-500">deze maand</div>
  </div>

  <!-- Floating route-badge -->
  <div class="absolute -bottom-4 -right-4 w-52 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up-delay-2">
    <div class="text-xs text-slate-500 mb-1">Route ploeg A</div>
    <div class="text-lg font-bold text-slate-900">8 opdrachten</div>
    <div class="mt-2 flex items-center gap-2 text-xs">
      <svg class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span class="text-slate-700 font-medium">142 km</span>
      <span class="text-slate-400">·</span>
      <span class="text-slate-500">4u 20m</span>
    </div>
  </div>

  <!-- Main browser mockup -->
  <div class="relative rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-100 border-b border-slate-200">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
      </div>
      <div class="flex-1 mx-4 px-3 py-1 text-xs text-slate-500 bg-white rounded-md border border-slate-200">cleanops.eu / planning</div>
    </div>

    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h3 class="text-base font-bold text-slate-900">Planning week 22</h3>
        <p class="text-xs text-slate-500">26 mei — 30 mei 2026</p>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-full bg-teal-100 border-2 border-white text-xs text-teal-700 font-bold flex items-center justify-center">A</div>
        <div class="w-7 h-7 rounded-full bg-blue-100 border-2 border-white -ml-2 text-xs text-blue-700 font-bold flex items-center justify-center">B</div>
        <div class="w-7 h-7 rounded-full bg-purple-100 border-2 border-white -ml-2 text-xs text-purple-700 font-bold flex items-center justify-center">C</div>
      </div>
    </div>

    <!-- Days row -->
    <div class="grid grid-cols-5 border-b border-slate-100 text-xs font-medium text-slate-500">
      {days.map((d, i) => (
        <div class={`px-3 py-2 text-center ${i === 0 ? 'bg-teal-50 text-teal-700' : ''}`}>{d}</div>
      ))}
    </div>

    <!-- Schedule -->
    <div class="divide-y divide-slate-100">
      {opdrachten.map((o) => (
        <div class="px-6 py-3 flex items-center gap-4">
          <div class="text-xs font-mono text-slate-500 w-12">{o.tijd}</div>
          <div class={`w-1 h-8 rounded-full ${
            o.color === 'teal' ? 'bg-teal-500' :
            o.color === 'blue' ? 'bg-blue-500' : 'bg-purple-500'
          }`}></div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium text-slate-900 truncate">{o.klant}</div>
            <div class="text-xs text-slate-500">{o.adres}</div>
          </div>
          <div class={`w-7 h-7 rounded-full text-xs font-bold flex items-center justify-center ${
            o.color === 'teal' ? 'bg-teal-100 text-teal-700' :
            o.color === 'blue' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700'
          }`}>{o.ploeg}</div>
        </div>
      ))}
    </div>
  </div>
</div>
