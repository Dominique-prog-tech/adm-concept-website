---
// Mockup specifiek voor Nimble: projecten-overzicht met vorderingsstaten
const projecten = [
  { naam: "Nieuwbouw Residentie Park", klant: "Bouwgroep Verstraete", voortgang: 75, status: "Uitvoering", color: "purple" },
  { naam: "Renovatie kantoor De Smet", klant: "De Smet & Co", voortgang: 40, status: "Uitvoering", color: "blue" },
  { naam: "Installatie HVAC project Noord", klant: "Industrie Noord", voortgang: 95, status: "Oplevering", color: "emerald" },
];
---

<div class="relative">
  <div class="absolute -inset-8 bg-gradient-to-br from-purple-500/20 via-fuchsia-400/10 to-pink-500/20 rounded-3xl blur-3xl"></div>

  <!-- Floating vorderingsstaat-badge -->
  <div class="absolute -top-6 -left-6 w-48 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up">
    <div class="text-xs text-slate-500 mb-1">Vorderingsstaat #VS-2026-08</div>
    <div class="text-xl font-bold text-slate-900">€ 87.500</div>
    <div class="mt-2 text-xs">
      <span class="text-emerald-600 font-medium">✓ Goedgekeurd</span>
      <span class="text-slate-400 ml-1">door klant</span>
    </div>
  </div>

  <!-- Floating uren-badge -->
  <div class="absolute -bottom-4 -right-4 w-52 bg-white rounded-xl shadow-xl p-4 z-10 animate-fade-up-delay-2">
    <div class="text-xs text-slate-500 mb-2">Uren deze week</div>
    <div class="flex items-end gap-1.5 h-12 mb-2">
      {[60, 85, 70, 95, 80].map((h) => (
        <div class="flex-1 rounded-t bg-gradient-to-t from-purple-600 to-purple-400" style={`height: ${h}%`}></div>
      ))}
    </div>
    <div class="flex items-center justify-between text-xs">
      <span class="text-slate-500">Ploeg Alpha</span>
      <span class="text-slate-900 font-semibold">187u</span>
    </div>
  </div>

  <!-- Main browser mockup -->
  <div class="relative rounded-2xl bg-white shadow-2xl border border-slate-200 overflow-hidden">
    <div class="flex items-center gap-2 px-4 py-3 bg-slate-100 border-b border-slate-200">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-400"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
        <div class="w-3 h-3 rounded-full bg-green-400"></div>
      </div>
      <div class="flex-1 mx-4 px-3 py-1 text-xs text-slate-500 bg-white rounded-md border border-slate-200">nimble-erp.eu / projecten</div>
    </div>

    <!-- Header -->
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h3 class="text-base font-bold text-slate-900">Lopende projecten</h3>
        <p class="text-xs text-slate-500">12 actief · 3 in oplevering</p>
      </div>
      <div class="px-3 py-1.5 rounded-md text-xs font-semibold text-white bg-purple-600">+ Nieuw project</div>
    </div>

    <!-- Project cards -->
    <div class="p-4 space-y-3">
      {projecten.map((p) => (
        <div class="p-4 rounded-xl border border-slate-200 hover:border-purple-200 hover:shadow-sm transition-all">
          <div class="flex items-start justify-between mb-2">
            <div class="flex-1 min-w-0">
              <div class="text-sm font-bold text-slate-900 truncate">{p.naam}</div>
              <div class="text-xs text-slate-500">{p.klant}</div>
            </div>
            <div class={`px-2 py-0.5 text-xs font-medium rounded-full ml-2 flex-shrink-0 ${
              p.color === 'emerald' ? 'bg-emerald-50 text-emerald-700' :
              p.color === 'purple' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700'
            }`}>{p.status}</div>
          </div>

          <div class="flex items-center gap-3">
            <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class={`h-full rounded-full ${
                p.color === 'emerald' ? 'bg-emerald-500' :
                p.color === 'purple' ? 'bg-purple-500' : 'bg-blue-500'
              }`} style={`width: ${p.voortgang}%`}></div>
            </div>
            <span class="text-xs font-semibold text-slate-700 w-10 text-right">{p.voortgang}%</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
