---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const clients = [
  {
    name: "Eurofinco",
    logo: "/images/clients/eurofinco.webp",
    description: t("clients.eurofinco"),
    href: "https://www.eurofinco.be",
  },
  {
    name: "Cares Assistance",
    logo: "/images/clients/cares-assistance.webp",
    description: t("clients.cares"),
    href: "https://www.cares-assistance.eu",
  },
  {
    name: "Hypotheekwereld",
    logo: "/images/clients/hypotheekwereld.webp",
    description: t("clients.hypotheekwereld"),
    href: "https://www.hypotheekwereld.be",
  },
  {
    name: "Tentmoment",
    logo: "/images/clients/tentmoment.webp",
    description: t("clients.tentmoment"),
    href: "https://www.tentmoment.be",
  },
];
---

<section class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <div class="inline-block px-3 py-1 rounded-full bg-amber-50 border border-amber-100 text-xs font-semibold text-amber-700 mb-4">
        {t("clients.badge")}
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
        {t("clients.heading")}
      </h2>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed">
        {t("clients.intro")}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        clients.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-lg transition-all"
            aria-label={`${c.name} — ${t("clients.visitWebsite")}`}
          >
            <div class="h-16 flex items-center justify-start mb-5">
              <img
                src={c.logo}
                alt={`${c.name} logo`}
                class="max-h-12 w-auto object-contain transition-transform group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-lg font-bold text-slate-900">{c.name}</h3>
              <svg
                class="w-3.5 h-3.5 text-slate-400 group-hover:text-brand-600 transition-colors"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{c.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
