---
import { getLangFromUrl, useTranslations } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const blogBase = t("route.blog");

const clients = [
  {
    name: "Eurofinco",
    logo: "/images/clients/eurofinco.webp",
    description: t("clients.eurofinco"),
    caseHref: null,
  },
  {
    name: "Cares Assistance",
    logo: "/images/clients/cares-assistance.webp",
    description: t("clients.cares"),
    caseHref: `${blogBase}/cares-assistance-lanceert-family-care`,
  },
  {
    name: "Hypotheekwereld",
    logo: "/images/clients/hypotheekwereld.webp",
    description: t("clients.hypotheekwereld"),
    caseHref: null,
  },
  {
    name: "Tentmoment",
    logo: "/images/clients/tentmoment.webp",
    description: t("clients.tentmoment"),
    caseHref: `${blogBase}/overname-tentmoment-door-veldeman`,
  },
];
---

<section class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <div class="inline-block px-3 py-1 rounded-full bg-amber-50 border border-amber-100 text-xs font-semibold text-amber-700 mb-4">
        {t("clients.badge")}
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 leading-tight">
        {t("clients.heading")}
      </h2>
      <p class="mt-6 text-lg text-slate-600 leading-relaxed">
        {t("clients.intro")}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        clients.map((c) => (
          <article class="group flex flex-col p-6 bg-white border border-slate-200 rounded-2xl hover:border-slate-300 hover:shadow-lg transition-all">
            <div class="h-16 flex items-center justify-start mb-5">
              <img
                src={c.logo}
                alt={`${c.name} logo`}
                class="max-h-12 w-auto object-contain"
                loading="lazy"
              />
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{c.name}</h3>
            <p class="text-sm text-slate-600 leading-relaxed flex-1">{c.description}</p>
            {c.caseHref && (
              <a
                href={c.caseHref}
                class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors"
              >
                {t("clients.readCase")}
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
