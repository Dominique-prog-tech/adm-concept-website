---
// Visuele hero-banner voor blogposts — vervangt generieke stockfoto's.
// Toont een logo (voor klantcase-blogs) OF een topic-icoon (voor algemene
// onderwerpen), op een brand-color gradient met abstracte decoraties.
// Volgt dezelfde design-language als CaseHeroBanner zodat blog en cases
// visueel verbonden aanvoelen.
//
// Wordt gerenderd zodra bannerColor + (bannerLogo OF bannerIcon) in de
// blog frontmatter staan. Anders fallback naar de oude `image`-foto in
// de templates.

interface Props {
  bannerColor: string;
  bannerLogo?: string;
  bannerIcon?: string;
  alt: string;
  /**
   * `full` = met eigen rounded-3xl + shadow + border, voor blog detail-pagina.
   * `card` = geen eigen rounded/shadow/border, voor inbedding in een card op
   *          het blog-overzicht.
   */
  variant?: "full" | "card";
}

const { bannerColor, bannerLogo, bannerIcon, alt, variant = "full" } = Astro.props;
const isCard = variant === "card";

// Lookup-maps met letterlijke Tailwind-klassen (purge-safe).
const gradients: Record<string, string> = {
  sky: "from-sky-50 via-white to-sky-100",
  blue: "from-blue-50 via-white to-blue-100",
  teal: "from-teal-50 via-white to-teal-100",
  purple: "from-purple-50 via-white to-purple-100",
  indigo: "from-indigo-50 via-white to-indigo-100",
  emerald: "from-emerald-50 via-white to-emerald-100",
  rose: "from-rose-50 via-white to-rose-100",
  amber: "from-amber-50 via-white to-amber-100",
  violet: "from-violet-50 via-white to-violet-100",
  cyan: "from-cyan-50 via-white to-cyan-100",
  fuchsia: "from-fuchsia-50 via-white to-fuchsia-100",
  slate: "from-slate-50 via-white to-slate-100",
};

const borderColors: Record<string, string> = {
  sky: "border-sky-200/60",
  blue: "border-blue-200/60",
  teal: "border-teal-200/60",
  purple: "border-purple-200/60",
  indigo: "border-indigo-200/60",
  emerald: "border-emerald-200/60",
  rose: "border-rose-200/60",
  amber: "border-amber-200/60",
  violet: "border-violet-200/60",
  cyan: "border-cyan-200/60",
  fuchsia: "border-fuchsia-200/60",
  slate: "border-slate-200/60",
};

const blob1: Record<string, string> = {
  sky: "bg-sky-200",
  blue: "bg-blue-200",
  teal: "bg-teal-200",
  purple: "bg-purple-200",
  indigo: "bg-indigo-200",
  emerald: "bg-emerald-200",
  rose: "bg-rose-200",
  amber: "bg-amber-200",
  violet: "bg-violet-200",
  cyan: "bg-cyan-200",
  fuchsia: "bg-fuchsia-200",
  slate: "bg-slate-200",
};

const blob2: Record<string, string> = {
  sky: "bg-sky-300",
  blue: "bg-blue-300",
  teal: "bg-teal-300",
  purple: "bg-purple-300",
  indigo: "bg-indigo-300",
  emerald: "bg-emerald-300",
  rose: "bg-rose-300",
  amber: "bg-amber-300",
  violet: "bg-violet-300",
  cyan: "bg-cyan-300",
  fuchsia: "bg-fuchsia-300",
  slate: "bg-slate-300",
};

const iconBg: Record<string, string> = {
  sky: "bg-sky-100",
  blue: "bg-blue-100",
  teal: "bg-teal-100",
  purple: "bg-purple-100",
  indigo: "bg-indigo-100",
  emerald: "bg-emerald-100",
  rose: "bg-rose-100",
  amber: "bg-amber-100",
  violet: "bg-violet-100",
  cyan: "bg-cyan-100",
  fuchsia: "bg-fuchsia-100",
  slate: "bg-slate-100",
};

const iconText: Record<string, string> = {
  sky: "text-sky-700",
  blue: "text-blue-700",
  teal: "text-teal-700",
  purple: "text-purple-700",
  indigo: "text-indigo-700",
  emerald: "text-emerald-700",
  rose: "text-rose-700",
  amber: "text-amber-700",
  violet: "text-violet-700",
  cyan: "text-cyan-700",
  fuchsia: "text-fuchsia-700",
  slate: "text-slate-700",
};

const accentSoft: Record<string, string> = {
  sky: "text-sky-300",
  blue: "text-blue-300",
  teal: "text-teal-300",
  purple: "text-purple-300",
  indigo: "text-indigo-300",
  emerald: "text-emerald-300",
  rose: "text-rose-300",
  amber: "text-amber-300",
  violet: "text-violet-300",
  cyan: "text-cyan-300",
  fuchsia: "text-fuchsia-300",
  slate: "text-slate-300",
};

const gradient = gradients[bannerColor] ?? gradients.sky;
const border = borderColors[bannerColor] ?? borderColors.sky;
const blob1Class = blob1[bannerColor] ?? blob1.sky;
const blob2Class = blob2[bannerColor] ?? blob2.sky;
const iconBgClass = iconBg[bannerColor] ?? iconBg.sky;
const iconTextClass = iconText[bannerColor] ?? iconText.sky;
const accentLight = accentSoft[bannerColor] ?? accentSoft.sky;

// Heroicons-stijl SVG paths voor de topic-iconen (hergebruik van de set
// die ook in realisaties/[...slug].astro wordt gebruikt voor capabilities).
const ICONS: Record<string, string> = {
  document: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  currency: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  users: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>`,
  computer: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
  link: `<path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>`,
  layers: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>`,
  chart: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  sparkle: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>`,
};
const iconPath = bannerIcon ? ICONS[bannerIcon] ?? ICONS.document : "";
---

<section
  class={`relative overflow-hidden bg-gradient-to-br ${gradient} aspect-[16/9] w-full ${
    isCard ? "" : `rounded-3xl shadow-2xl border ${border}`
  }`}
>
  {/* Subtiele dot-grid achtergrond */}
  <div
    class="absolute inset-0 opacity-[0.05]"
    style="background-image: radial-gradient(circle at 1px 1px, #0f172a 1px, transparent 0); background-size: 26px 26px;"
  >
  </div>

  {/* Vervaagde brand-color blobs voor diepte */}
  <div
    class={`absolute -top-20 -right-24 w-80 h-80 ${blob1Class} rounded-full blur-3xl opacity-50 pointer-events-none`}
  >
  </div>
  <div
    class={`absolute -bottom-24 -left-20 w-96 h-96 ${blob2Class} rounded-full blur-3xl opacity-30 pointer-events-none`}
  >
  </div>

  {/* Decoratieve verbindings-lijnen (netwerk metaphor) */}
  <svg
    class={`absolute top-6 right-6 lg:top-10 lg:right-10 w-24 h-24 lg:w-32 lg:h-32 ${accentLight} opacity-40 pointer-events-none`}
    viewBox="0 0 100 100"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    aria-hidden="true"
  >
    <circle cx="20" cy="20" r="3" fill="currentColor"></circle>
    <circle cx="80" cy="20" r="3" fill="currentColor"></circle>
    <circle cx="50" cy="50" r="3" fill="currentColor"></circle>
    <circle cx="20" cy="80" r="3" fill="currentColor"></circle>
    <circle cx="80" cy="80" r="3" fill="currentColor"></circle>
    <line x1="20" y1="20" x2="50" y2="50"></line>
    <line x1="80" y1="20" x2="50" y2="50"></line>
    <line x1="20" y1="80" x2="50" y2="50"></line>
    <line x1="80" y1="80" x2="50" y2="50"></line>
    <line x1="20" y1="20" x2="80" y2="20" stroke-dasharray="2 3"></line>
    <line x1="20" y1="80" x2="80" y2="80" stroke-dasharray="2 3"></line>
  </svg>

  <svg
    class={`absolute bottom-6 left-6 lg:bottom-10 lg:left-10 w-20 h-20 lg:w-28 lg:h-28 ${accentLight} opacity-30 pointer-events-none`}
    viewBox="0 0 100 100"
    fill="none"
    stroke="currentColor"
    stroke-width="1.2"
    aria-hidden="true"
  >
    <path d="M 10 50 Q 30 20, 50 50 T 90 50" stroke-dasharray="3 4"></path>
    <path d="M 10 65 Q 30 35, 50 65 T 90 65"></path>
    <path d="M 10 35 Q 30 5, 50 35 T 90 35" stroke-dasharray="3 4"></path>
  </svg>

  {/* Centrale visuele content: logo OF icoon */}
  <div class="absolute inset-0 flex items-center justify-center px-6">
    {bannerLogo ? (
      <div
        class={`bg-white rounded-2xl shadow-xl shadow-slate-900/10 p-6 sm:p-8 ${
          isCard
            ? "w-32 h-32 sm:w-40 sm:h-40 lg:w-44 lg:h-44"
            : "w-40 h-40 sm:w-48 sm:h-48 lg:w-56 lg:h-56 lg:p-10"
        } flex items-center justify-center`}
      >
        <img
          src={bannerLogo}
          alt={alt}
          class="max-w-full max-h-full object-contain"
          loading={isCard ? "lazy" : "eager"}
        />
      </div>
    ) : (
      <div
        class={`${iconBgClass} ${iconTextClass} rounded-full shadow-xl shadow-slate-900/10 ${
          isCard
            ? "w-24 h-24 sm:w-28 sm:h-28 lg:w-32 lg:h-32 p-6"
            : "w-28 h-28 sm:w-32 sm:h-32 lg:w-40 lg:h-40 p-7 lg:p-9"
        } flex items-center justify-center`}
      >
        <svg
          class="w-full h-full"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <Fragment set:html={iconPath} />
        </svg>
      </div>
    )}
  </div>
</section>
