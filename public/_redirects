# Cloudflare Pages redirects
# Format: <oud-pad> <nieuw-pad> <status>
# Wildcards (*) en placeholders (:slug) worden ondersteund.

# === Oude Odoo helpdesk -> nieuwe support-pagina ===
/helpdesk/adm-concept-support-1        /support  301
/helpdesk/adm-concept-support-1/*      /support  301
/helpdesk                              /support  301
/helpdesk/*                            /support  301

# === Oude Odoo contact/shop paden -> nieuwe equivalenten ===
/shop                                  /producten           301
/shop/*                                /producten           301

# === Eventuele Odoo /web paden ===
/web/login                             /                    301
/web                                   /                    301

# === Oude WordPress/Odoo paden (404's uit Search Console, mei 2026) ===

# Blogposts: oude slugs -> nieuwe (specifiek, vóór de catch-all)
/blogs/post/cares-assistance-lanceert-nieuw-product-family-care                  /blog/cares-assistance-lanceert-family-care         301
/cares-assistance-lanceert-nieuw-product-family-care                             /blog/cares-assistance-lanceert-family-care         301
/cares-assistance-lanceert-nieuw-product-family-care/*                           /blog/cares-assistance-lanceert-family-care         301
/blogs/post/overname-tentmoment-veldeman                                         /blog/overname-tentmoment-door-veldeman             301
/blogs/post/peppol-ondersteuning-nu-beschikbaar-voor-al-onze-maatwerkplatformen  /blog/peppol-ondersteuning-voor-maatwerkplatformen  301
# Blog-index + overige oude blog-paden (author, categorie, ...) -> blog
/blogs                          /blog                    301
/blogs/*                        /blog                    301
# Oude WordPress category-archieven -> blog
/category                       /blog                    301
/category/*                     /blog                    301

# Productpagina's: oude top-level slugs -> /producten/*
/cleanops                       /producten/cleanops      301
/cleanops/*                     /producten/cleanops      301
/creditsoft                     /producten/creditsoft    301
/creditsoft/*                   /producten/creditsoft    301
/nimble                         /producten/nimble        301
/nimble/*                       /producten/nimble        301

# Cases -> realisaties (incl. oude /case-<naam> WordPress-URLs)
/cases                          /realisaties             301
/cases/*                        /realisaties             301
/case-*                         /realisaties             301

# Oude service/tech-pagina's -> diensten
/features                       /diensten                301
/features/*                     /diensten                301
/delphi                         /diensten                301
/delphi/*                       /diensten                301

# Privacy: oude naam -> nieuwe
/privacybeleid                  /privacy                 301
/privacybeleid/*                /privacy                 301

# Oud Odoo-forum -> home
/forum                          /                        301
/forum/*                        /                        301
